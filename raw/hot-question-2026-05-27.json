g.com/80/v2-a4b0b52b561281109c51e4957cb20130_1440w.png", "night_icon": "https://pic3.zhimg.com/80/v2-10ef6526c602e55a8c606e46aa0cc586_1440w.png"}, "feed_specific": {"answer_count": 19}, "target": {"title_area": {"text": "如何评价谭成义与凯圣王三分化训练？"}, "excerpt_area": {"text": "本人系统健身训练已有半年，因健身房就在公司楼下，健身与上班节奏保持一致，所以一周五练，礼拜六日就休息了。故一直用的五分化训练计划。 最近刷到谭成义与凯圣王一起制定的三分化训练。有想尝试转换训练计划。但看他们制定的三分化训练不免有些许嘀咕。 想看看诸位如何评价这份计划？ 计划分为 Push 日包含胸、肩前中束、三头；Pull 日包含背、肩后束、二头；Legs 日包含下肢肌群。 1.push 日计划：杠铃卧推、哑铃上斜卧推、双杠臂屈伸、仰卧臂屈伸、 Y 字侧平举； 2.Pull 日计划：单侧钢线下拉、对握下拉、单手器械划船、坐姿划船、钢线弯举； 3.Legs 日计划：单腿硬拉、保加利亚蹲、颈前深蹲、罗马尼亚硬拉、山羊挺身。 我是觉得手臂跟肩的动作少了。平时五分化我都是一个部位练四个动作左右，突然换成只有一个动作感觉练不全面吧？ 欢迎大家发表看法。"}, "image_area": {"url": "https://picx.zhimg.com/80/v2-f78aea9d97cbcfc40298537543a47164_1440w.webp?source=1def8aca"}, "metrics_area": {"text": "67 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2035676812785756032"}}, "attached_info": "CkkIpIWtkqqUzOFgEAMaCTExOTQxMTg1MCClg/DPBjAAODRAFXITMjAzNTY3NjgxMjc4NTc1NjAzMngAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "22_1779853943.255835", "card_id": "Q_1969812000155591247", "feed_specific": {"answer_count": 78}, "target": {"title_area": {"text": "邵佳一球员时代是什么水平，放到现在能在国家队当大腿吗？"}, "excerpt_area": {"text": ""}, "image_area": {"url": "https://pic4.zhimg.com/50/v2-dd97fc0099c5b426e34b98fbfedbc595_b.jpg"}, "metrics_area": {"text": "66 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/1969812000155591247"}}, "attached_info": "CkkIpIWtkqqUzOFgEAMaCTExNzIzMTY2NSDCyLHIBjAAOF5AFnITMTk2OTgxMjAwMDE1NTU5MTI0N3gAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "23_1779853943.256227", "card_id": "Q_20526863", "feed_specific": {"answer_count": 30}, "t