himg.com/v2-668235a3f9829aa8e1335c9c2f029900.png"}, "metrics_area": {"text": "126 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2040810498376085990"}}, "attached_info": "CkkI3/fFno6b6PkpEAMaCTExOTU5NjE2NSDD3brQBjAAOCNACXITMjA0MDgxMDQ5ODM3NjA4NTk5MHgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "10_1780545759.827537", "card_id": "Q_2045619984928355041", "card_label": {"type": "new", "icon": "https://pic2.zhimg.com/80/v2-a4b0b52b561281109c51e4957cb20130_1440w.png", "night_icon": "https://pic3.zhimg.com/80/v2-10ef6526c602e55a8c606e46aa0cc586_1440w.png"}, "feed_specific": {"answer_count": 16}, "target": {"title_area": {"text": "如何评价长沙热身赛中国男篮 6 人上双王俊杰 18+14 徐昕 10+8，82-78 战胜 FMP 拉德尼基？"}, "excerpt_area": {"text": "6 月 3 日讯 男篮热身赛长沙站，中国男篮对阵塞尔维亚 FMP 拉德尼基。 比赛开始，双方开场便陷入缠斗，比分始终紧咬，王俊杰稳定输出，徐昕连投带罚带队咬住，轮换阶段中国男篮陷入 3 分钟的得分荒，对手打出 10-0 的攻击波取得领先，焦泊乔挺身而出里突外投连得 7 分，次节庞峥麟连得 8 分率队打出 10-0 的攻击波抹平分差，此后中国男篮命中率下降，FMP 拉德尼基连续拿分，半场战罢中国男篮 39-46 落后 FMP 拉德尼基。易边再战，中国男篮展开反击，王俊杰延续火力，中国男篮多点开花完成反超，末节双方争夺陷入白热化，关键时刻廖三宁和王俊杰先后飙中三分，庞峥麟也投进关键中投，最终，中国男篮 82-78 力克 FMP 拉德尼基，取得胜利。"}, "image_area": {"url": "https://pica.zhimg.com/50/v2-bf1af28f103648d0506be552da73bcb6_b.jpg"}, "metrics_area": {"text": "104 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2045619984928355041"}}, "attached_info": "CkkI3/fFno6b6PkpEAMaCTExOTgwMDkzNiDy24DRBjAAOBBACnITMjA0NTYxOTk4NDkyODM1NTA0MXgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "11_1780545759.828297", "card_id": "Q_1913335161661154588", "card_label": {"type": "hot", "icon": "https://pic2.zhimg.com/80/v2-266e83dbee46dce23b718e0531cb7d3a_1440w.png", "night_icon": "https://pic3.zhimg.com/80/v2-c89199839c237b87e52f010bb