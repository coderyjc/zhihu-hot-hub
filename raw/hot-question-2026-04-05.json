e6395062ef3b1ca844ec0de324b6_b.jpg"}, "metrics_area": {"text": "53 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2699037621"}}, "attached_info": "CkEIsZm/5tuXxcgnEAMaCTExMTUxNjQ1OSCSi425BjAAOIIBQBpyCjI2OTkwMzc2MjF4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "27_1775365966.54020", "card_id": "Q_2023728435508381108", "feed_specific": {"answer_count": 158}, "target": {"title_area": {"text": "NASA 公布阿尔忒弥斯 2 号上拍摄的地球照片，哪些细节值得关注？"}, "excerpt_area": {"text": "NASA 宇航员、阿耳忒弥斯二号任务指挥官里德·怀斯曼在完成地月转移轨道点火后，从猎户座飞船的舷窗拍下了这张地球照片。照片中可见两处极光（右上和左下），以及地球遮挡太阳时显现的黄道光（右下）。 这张照片以及另一张地球照片，是阿耳忒弥斯二号宇航员传回的首批图像。更多来自猎户座飞船的照片将陆续分享。 Image credit: NASA/Reid Wiseman"}, "image_area": {"url": "https://pic2.zhimg.com/50/v2-b6c80270e9a0682c0d2e66c69bbdfc6f_b.jpg"}, "metrics_area": {"text": "53 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2023728435508381108"}}, "attached_info": "CkoIsZm/5tuXxcgnEAMaCTExOTAxOTgxMSDak8LOBjAAOI4GQBtyEzIwMjM3Mjg0MzU1MDgzODExMDh4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "28_1775365966.54903", "card_id": "Q_56814700", "feed_specific": {"answer_count": 964}, "target": {"title_area": {"text": "历史上有哪些刚刚发明出来，就被取代或淘汰的东西？"}, "excerpt_area": {"text": "看起来非常有前景的发明，刚发明出来就被取代了的例子？ 以及有哪些发明，发明出来不久就被淘汰掉，连取代品都没有的例子？"}, "image_area": {"url": "https://picx.zhimg.com/80/v2-2be63f14a7da492acb478cc55049d7ba_1440w.webp?source=1def8aca"}, "metrics_area": {"text": "51 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/56814700"}}, "attached_info": "Cj4IsZm/5tuXxcgnEAMaCDE0OTQ2MzM5IPzr/8UFMAA41WBAHHIINTY4MTQ3MDB4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "29_1775365966.55346", "card_id": "Q_2022101442727614368", "feed_specific": {"answer_count": 120}, "target": {"title_area": {"text": "华强北商户抛售内存条，存储行业供需拐点已经来了吗？"}, "excerpt_area": {"text": "财联社 3 月 30 日讯（记者 王碧微） 连续数月走高的内存条价格，现货市场价格出现了明显松动。DRAMeXchange 的追踪数据显示，3 月以来 DDR5 模组现货价格呈现跌势。今日，财联社记者走访深圳华强北电子市场了解到，自上周以来，DDR5 内存条现货价格降幅明显，有商户报价较上周下跌超三成。 在现货价格大幅回落的同时，TrendForce 集邦咨询资深分析师许家源向财联社记者指出，DDR5 颗粒与模组的合约价涨势预计将从今年二季度延续至下半年，这将对现货价格形成支撑。 现货在跌，合约还在涨。这轮降价是行业拐点的信号，还是渠道层面的短期调整？ 谁在抛？为什么抛？ 内存条是计算机中用于与 CPU 直接交换数据的核心临时存储部件。在过去的半年里，在上游产能被 AI 挤占等因素的作用下，内存条价格激增。 今日，财联社记者在深圳华强北电子市场了解到，自上周以来，DDR5 内存条现货价格降幅明显。以 32G DDR5 内存条为例，多家装机商户表示，上周同款产品报价约 3000 元 / 条，而本周报价已降至 2500 元 / 条甚至更低，降幅在 500 至 1050 元不等。 一位商家给财联社记者的报价单，32G DDR5 内存条报价 1950 元 / 条 图片来源：财联社记者 / 摄 不止华强北，整个市场的内存条现货价格都呈现下跌趋势。 根据慢慢买 App，京东商城的一款金士顿 64GB（32GB×2）DDR5 6000 频率台式机内存目前售价为 7750.26 元，而在两个月前，这款产品的价格为 11781 元。 国际市场也出现了同步回落。 有媒体报道称，过去一周，美国多家零售商的 DDR5 内存出现大范围降价。 财联社记者于 camelcamelcamel 平台查询美国亚马逊网站上一款海盗船的复仇者（VENGEANCE）系列 DDR5 32GB 内存条的价格发现，该产品在一周前从 539.99 美元降价 80 美元 -459.99 美元。 或受此影响，美光科技和闪迪的股价上周分别 华强北商户开始抛售内存条 存储行业的供需拐点来了吗？"}, "image_area": {"url": "https://picx.zhimg.com/v2-3c812a5862871fa03cbf6fa72e86bf41.png"}, "metrics_area": {"text": "50 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2022101442727614368"}}, "attached_info": "CkoIsZm/5tuXxcgnEAMaCTExODk2MjU1OSCYvarOBjAAOMkCQB1yEzIwMjIxMDE0NDI3Mjc2MTQzNjh4AKoBCWJpbGxib2FyZNIBAA=="}], "paging": {"is_end": true, "is_start": false, "next": "", "previous": "", "totals": 0}, "fresh_text": "热榜已更新", "display_num": 15, "display_first": true, "fb_bill_main_rise": 0, "head_zone": {"type": "billboard_lantern", "data": [{"id": "2023882345141268786", "link_url": "https://www.zhihu.com/special/2023074101875492733", "title": 