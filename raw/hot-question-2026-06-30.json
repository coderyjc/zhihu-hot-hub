.zhimg.com/80/v2-1d9ae146144d05ea91b384de3c5fc830_720w.webp?source=1def8aca"}, "metrics_area": {"text": "68 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2051621252389943216"}}, "attached_info": "CkoIg4ix3Yqgv/lsEAMaCTEyMDA2MDYxMiCPhtjRBjAAOKoDQBVyEzIwNTE2MjEyNTIzODk5NDMyMTZ4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "22_1782790808.871727", "card_id": "Q_652795747", "feed_specific": {"answer_count": 334}, "target": {"title_area": {"text": "汉语是世界上最言简意赅的语言吗？"}, "excerpt_area": {"text": "象形文字是表达语意最简练的语言吗？"}, "image_area": {"url": "https://picx.zhimg.com/80/v2-8c67916231e7f81d2bbd8c02e11f6b09_1440w.webp?source=1def8aca"}, "metrics_area": {"text": "68 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/652795747"}}, "attached_info": "CkAIg4ix3Yqgv/lsEAMaCTEwNzM0MzQwOSCUzOewBjAAOIMIQBZyCTY1Mjc5NTc0N3gAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "23_1782790808.872332", "card_id": "Q_19708518", "card_label": {"type": "new", "icon": "https://pic2.zhimg.com/80/v2-a4b0b52b561281109c51e4957cb20130_1440w.png", "night_icon": "https://pic3.zhimg.com/80/v2-10ef6526c602e55a8c606e46aa0cc586_1440w.png"}, "feed_specific": {"answer_count": 458}, "target": {"title_area": {"text": "如何了解和认识自己的潜意识？"}, "excerpt_area": {"text": "当一个人的行为举止显性思维与潜意识里的「我」一致性越高的时候，这个人在生理上就会越有满足感和幸福感；反之则越缺乏。 例如当潜意识里的「我」对自己现有的状况感到不满的时候，显性思维中的我如果还是要自欺欺人的去自我蒙蔽自我安慰，生理上就会出现焦躁不安的现象，如果显性思维中的我顺应了潜意识的我，去反思现状，探索问题，寻求方案，那么立马就会感到豁然开朗。 当一件所谓「坏事」出现在你的面前的时候，其实只是因为潜意识的你把它当成坏事才会让你觉得这是坏事。 因此想要让自己的心情变好，要么就按照潜意识里的「我」去做，要么就改变潜意识里的「我」。 我们常常发现自己有时违背内心做了一些事情，遇到问题会首先内省或者避免冲突的方式来解决，但归咎于自己之后，潜意识里会不爽。 有什么书籍或者方式更好的帮助自己了解自己的潜意识，更好的了解自己的内心呢？"}, "image_area": {"url": "https://pic4.zhimg.com/50/v2-67a014c1a66489557f24e20b1751ccc5_b.jpg"}, "metrics_area": {"text": "64 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/19708518"}}, "attached_info": "CjsIg4ix3Yqgv/lsEAMaBTYzNDU3IJ/wy+8EMAA4hDRAF3IIMTk3MDg1MTh4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "24_1782790808.873273", "card_id": "Q_2054934053560607671", "feed_specific": {"answer_count": 194}, "target": {"title_area": {"text": "警方通报「东鹏特饮创始人不喝自家饮料」，造谣者被刑拘，涉及哪些法律问题？谣言为啥能让其市值蒸发 70 亿？"}, "excerpt_area": {"text": "6 月 29 日，就网传「东鹏特饮创始人不喝自家饮料」事件，深圳市公安局南山分局发布警情通报： 近日，我局接东鹏饮料 (集团) 股份有限公司报案，反映网传该企业创始人不喝自家品牌饮料等大量不实信息。 经我局溯源调查，罗某某 (男，39 岁，自媒体从业人员) 为博取关注、引流牟利，借助 AI 工具编造虚假信息散布谣言，相关内容广泛传播，造成恶劣社会影响。目前，罗某某已被公安机关依法刑事拘留，案件正在进一步侦办中。 警方郑重警示：网络非法外之地。公安机关常态化开展网络谣言打击整治，对编造传播网络谣言等违法犯罪行为一律彻查严惩。请广大网友自觉抵制不实信息，不造谣不信谣不传谣，共同维护清朗网络环境。 深圳警方通报：用 AI 编造散布「东鹏特饮创始人不喝自家饮料」谣言，罗某某（男，39 岁）被刑拘 五天前，正是这段十几秒的「饭局视频」，把东鹏饮料推上了舆论的风口浪尖。画面里，有人递了瓶东鹏特饮给创始人林木勤，林木勤摆摆手说：「我平时不喝这个，喝别的。」资本市场反应迅速。6 月 22 日至 26 日，东鹏饮料 A 股、 H 股持续下行，一周市值合计蒸发超 70 亿元。百度安全验证"}, "image_area": {"url": "https://picx.zhimg.com/80/v2-aaa84caa2cd7b4682dab2dd60c1176a1_720w.webp?source=1def8aca"}, "metrics_area": {"text": "59 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2054934053560607671"}}, "attached_info": "CkoIg4ix3Yqgv/lsEAMaCTEyMDIwNTI2NiDZoIjSBjAAOO4CQBhyEzIwNTQ5MzQwNTM1NjA2MDc2NzF4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "25_1782790808.874346", "card_id": "Q_1957535466673930829", "feed_specific": {"answer_count": 28}, "target": {"title_area": {"text": "为什么纣王似乎对周文王的扩张完全无动于衷？"}, "excerpt_area": {"text": "今年灭一国，明年灭一国，怎么也该听到些风声，有些反应吧？"}, "image_area": {"url": "https://pica.zhimg.com/v2-5abd79dd6807c2d39178fb003ac8282a_xl.jpg?source=57bbeac9"}, "metrics_area": {"text": "58 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/1957535466673930829"}}, "attached_info": "CkkIg4ix3Yqgv/lsEAMaCTExNjgyMDk2MyDY9f7GBjAAOElAGXITMTk1NzUzNTQ2NjY3MzkzMDgyOXgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "26_1782790808.875152", "card_id": "Q_2053253895510664872", "feed_specific": {"answer_count": 64}, "target": {"title_area": {"text": "我发现不管什么昆虫，只要在它身上滴两滴乙酸丁酯，它就会立刻抽搐，然后不到二十秒死掉，这是什么原因？"}, "excerpt_area": {"text": "比氰化氢，甚至世面上所有杀虫剂都要快。"}, "image_area": {"url": "https://pica.zhimg.com/80/v2-f5e487e0c9495574e11af906bd7195ed_720w.webp?source=1def8aca"}, "metrics_area": {"text": "57 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2053253895510664872"}}, "attached_info": "CkoIg4ix3Yqgv/lsEAMaCTEyMDEyODYzOSCU5+/RBjAAOKQDQBpyEzIwNTMyNTM4OTU1MTA2NjQ4NzJ4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "27_1782790808.876117", "card_id": "Q_2053789215197078646", "feed_specific": {"answer_count": 48}, "target": {"title_area": {"text": "2026 年 WTT 美国大满贯，国乒自带球桌是真实的吗？"}, "excerpt_area": {"text": "#2026 年 WTT 美国大满贯# 不懂就问，既然比赛时还是用举办方的球桌，为什么不用比赛时的球桌适应，大费周章自带球桌的作用是什么？"}, "image_area": {"url": "https://pic1.zhimg.com/80/v2-5848110eed6a75566cbc519f861b905a_1440w.webp?source=1def8aca"}, "metrics_area": {"text": "55 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2053789215197078646"}}, "attached_info": "CkkIg4ix3Yqgv/lsEAMaCTEyMDE1MTcxNCCizPfRBjAAOEtAG3ITMjA1Mzc4OTIxNTE5NzA3ODY0NngAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "28_1782790808.876694", "card_id": "Q_2054939503928815666", "feed_specific": {"answer_count": 66}, "target": {"title_area": {"text": "韩国队即将回国，韩极端网民对主帅洪明甫发出死亡威胁，警方密切监控仁川机场等地，如何看待此次韩国舆论？"}, "excerpt_area": {"text": "韩国队晋级 2026 年世界杯 32 强的希望于 28 日彻底破灭，引发了公众对主教练洪明甫日益强烈的批评。 当地时间 28 日，韩国队主帅洪明甫在发布会上主动宣布辞职。他说：「向支持国家队的国民们真诚致歉，我将从教练岗位退下来。」 据韩国足协透露，由洪明甫执教的国家队将于 30 日上午经由仁川国际机场返回国内。回国的航班中仅有 8 名成员同行，包括主帅洪明甫以及门将赵贤祐、金玟哉、黄仁范、黄喜灿等球员。队长孙兴慜等其余球员将根据各自俱乐部安排分批回国，预计持续至下月 1 日完成返程。 官方目前已经取消接机或庆祝活动，这也是自 2002 年韩日世界杯以来，韩国队首次在结束海外世界杯征程后取消正式回国仪式。 以往即便成绩不理想，韩国队回国时仍会举行一些接机活动。2014 年巴西世界杯时，球队同样以 1 平 2 负止步小组赛，但仍在回国时受到欢迎。 28 日，韩国网络上出现一些针对洪明甫的恶意帖子。其中一张标题为《洪明甫的最后战术部署》的恶搞图片，图中这位教练正在做战术讲解，配文写道：「一到机场，大家千万别回头，各自散开逃命吧。」 韩国警方表示，将以涉嫌恐吓等罪名对发布威胁性帖文的行为展开调查，正在追踪发帖者，并将对仁川机场等地保持高度警惕，严防发生突发状况。"}, "image_area": {"url": "https://picx.zhimg.com/80/v2-28ab7ba4531dbeaaf11cb875c829e6b5_720w.webp?source=1def8aca"}, "metrics_area": {"text": "53 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2054939503928815666"}}, "attached_info": "CkkIg4ix3Yqgv/lsEAMaCTEyMDIwNTQ2MCDsqojSBjAAOHtAHHITMjA1NDkzOTUwMzkyODgxNTY2NngAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "29_1782790808.877806", "card_id": "Q_514078942", "feed_specific": {"answer_count": 64}, "target": {"title_area": {"text": "有人见过武则天的画像吗，非常好奇？"}, "excerpt_area": {"text": ""}, "image_area": {"url": "https://pica.zhimg.com/80/v2-c71803800386c1ae5bc491435d4d21ae_720w.webp?source=1def8aca"}, "metrics_area": {"text": "53 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/514078942"}}, "attached_info": "Cj8Ig4ix3Yqgv/lsEAMaCDc2NTIxMjA5IP+J2I8GMAA4ugFAHXIJNTE0MDc4OTQyeACqAQliaWxsYm9hc