f4_720w.webp?source=1def8aca"}, "metrics_area": {"text": "89 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2024804046981048166"}}, "attached_info": "CkkI5Nvx9+KhrpwPEAMaCTExOTA1MDQwNiCX59HOBjAAOBxAE3ITMjAyNDgwNDA0Njk4MTA0ODE2NngAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "20_1775538619.53541", "card_id": "Q_2024754145689694623", "card_label": {"type": "new", "icon": "https://pic2.zhimg.com/80/v2-a4b0b52b561281109c51e4957cb20130_1440w.png", "night_icon": "https://pic3.zhimg.com/80/v2-10ef6526c602e55a8c606e46aa0cc586_1440w.png"}, "feed_specific": {"answer_count": 20}, "target": {"title_area": {"text": "美军特种兵潜入伊朗救人场面失控，运输机「失灵」了，为什么会出现这种情况？暴露出美军的哪些短板？"}, "excerpt_area": {"text": "【营救行动变「闹剧」？#美军营救飞行员内幕曝光#】#美军特种兵潜入伊朗救人场面失控#，运输机「失灵」了。据路透社报道，大约 100 名美军特种兵 4 日进入伊朗执行了营救任务。据《纽约时报》5 日披露的部分细节，被击落的 F-15E 战机武器官脚踝扭伤，藏匿于一处山顶岩缝中，以躲避伊朗方面的搜索，随身武器仅有一把手枪。美军营救人员爬上一道山脊后，找到了这名武器官，并在 5 日天亮前将其转移至撤离地点。然而，承担部分人员运送任务的两架 MC-130 运输机却「失灵」了，出现机械故障无法起飞。指挥官决定，临时加派军机进入伊朗。一些体形相对较小的涡轮螺旋桨飞机最终把受困人员分批带回。为实施营救，美军对伊朗电子设备实施干扰，并轰炸施救地点周边关键道路，切断伊朗方面的来路。美方称，撤出伊朗前，美军炸毁了 4 架直升机和两架故障 MC-130 飞机，以免落入敌手。不过，伊朗武装部队哈塔姆安比亚中央总部发言人 5 日称，经现场专家进一步调查显示，美军行动中共有两架「黑鹰」直升机和两架 C-130 运输机被击落。消息人士还说，「敌人」试图摧毁被击落飞机的残骸，甚至摧毁身亡美军士兵的尸体。据美方披露，在找到 F-15E 战机武器官之前，美国中央情报局还发起了一场欺骗行动，他们在伊朗散布消息称，美军已经找到这名飞行员，正通过地面转移将其送出境外。"}, "image_area": {"url": "https://picx.zhimg.com/80/v2-37c1ff61f328456770956df5ce0168a8_720w.webp?source=1def8aca"}, "metrics_area": {"text": "89 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2024754145689694623"}}, "attached_info": "CkkI5Nvx9+KhrpwPEAMaCTExOTA0ODM2NCCeitHOBjAAODBAFHITMjAyNDc1NDE0NTY4OTY5NDYyM3gAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "21_1775538619.54727", "card_id": "Q_1955268439397598059", "feed_specific": {"answer_count": 39}, "target": {"title_area": {"text": "如何看待业内人士谈 PS6 主机「别指望有 RTX 5090 级别的性能」？"}, "excerpt_area": {"text": "据外媒 playground 报道，业内知情人士兼 PS6 活跃爆料者「Moore’s Law is Dead」日前表示，PS6 主机仅能在特定应用场景下与 RTX 5090 一较高下，若对比 RTX 5090 的整体游戏性能，PS6 主机则基本上没有胜算。 在近期一则关于 PS6 传闻的视频中，「Moore’s Law is Dead」称 PS6 主机上搭载的 AMD Orion 系统级芯片在光栅化性能方面远逊于 RTX 5090，因为 Orion 的光栅化性能整体偏弱。PS6 主机的光线追踪能力将近似于 RTX 5080，仅在低负载光追场景中能与 RTX 5090 显卡抗衡。「除极端情况外，大多数场景下的性能表现会更接近 RTX 5080 的水准。」 据此前的泄露规格显示，PS6 主机将配备 Zen 6 处理器，提供 34-40 万亿次浮点运算性能。在内存方面，PS6 主机或将采用 GDDR7 显存，最高支持 40GB 容量，预计在多数游戏中可实现画质模式 4K/60 帧，性能模式 4K/120 帧的表现。当然，一切消息应以索尼官方为准，还望各位玩家理性看待。 业内人士谈 PS6 主机：别指望有 RTX 5090 级别的性能！"}, "image_area": {"url": "https://picx.zhimg.com/80/v2-f08bff23142033e30166e09348477389_720w.webp?source=1def8aca"}, "metrics_area": {"text": "88 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/1955268439397598059"}}, "attached_info": "CkkI5Nvx9+KhrpwPEAMaCTExNjc0NzkzNSCD993GBjAAODVAFXITMTk1NTI2ODQzOTM5NzU5ODA1OXgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "22_1775538619.56230", "card_id": "Q_2023050107348631766", "card_label": {"type": "new", "icon": "https://pic2.zhimg.com/80/v2-a4b0b52b561281109c51e4957cb20130_1440w.png", "night_icon": "https://pic3.zhimg.com/80/v2-10ef6526c602e55a8c606e46aa0cc586_1440w.png"}, "feed_specific": {"answer_count": 15}, "target": {"title_area": {"text": "武汉的石楠花开了，听说一株石楠能养活 53 种昆虫，但它的味道让人捂鼻，你会因为生态价值包容石楠花吗？"}, "excerpt_area": {"text": "四月的武汉，樱花季刚过，另一种花悄无声息地开了。它的出现，总是伴随着一个经典话题——味道。 石楠花，有人形容它「又腥又臭」，有人说像某种难以言说的气味。社交平台上，每年这个时候都会掀起一轮讨论：武汉的石楠花怎么又开了？但很少有人知道，这种让人捂鼻的花，其实是城市的「隐形功臣」。武汉市园林和林业局的数据显示，一株石楠能养活 53 种昆虫，蜂类、蝇类、蝴蝶、蛾类都靠它提供食物。它还有降尘、抗污染、降噪隔音的本事，而且耐旱耐贫瘠，养护成本低，堪称绿篱和道路隔离带的「中流砥柱」。 一边是生态价值，一边是刺鼻气味。石楠花就这样站在了讨论的中心。有人说，为了城市绿化，忍几天就过去了；也有人觉得，明明可以种别的花，为什么非要留它？ 你身边有石楠花吗？它的味道你能接受吗？欢迎聊聊你的真实感受。"}, "image_area": {"url": "https://pic3.zhimg.com/50/v2-cc12ce42d03a23d845bda1211e8aab34_b.jpg"}, "metrics_area": {"text": "84 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2023050107348631766"}}, "attached_info": "CkkI5Nvx9+KhrpwPEAMaCTExODk5NTk3NCCcpLjOBjAAOBpAFnITMjAyMzA1MDEwNzM0ODYzMTc2NngAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "23_1775538619.57178", "card_id": "Q_2024796035973662135", "card_label": {"type": "new", "icon": "https://pic2.zhimg.com/80/v2-a4b0b52b561281109c51e4957cb20130_1440w.png", "night_icon": "https://pic3.zhimg.com/80/v2-10ef6526c602e55a8c606e46aa0cc586_1440w.png"}, "feed_specific": {"answer_count": 30}, "target": {"title_area": {"text": "郑丽文率团访陆，为何选择江苏、上海、北京？此行会讨论哪些议题？"}, "excerpt_area": {"text": "郑丽文访问大陆的消息响彻两岸，一方面，让人们看到两岸可以通过和平的方式解决自家的问题。另一方面，民进党当局对郑丽文要参访大陆感到极为不安，甚至对其发出恐吓，进行施压。但郑丽文始终坚定初心，她认为两岸同根同源、同属一个中国，只有在坚持「九二共识」、反对「台独」的基础上，才能实现两岸关系和平发展，只有开展对话交流才是解决问题的正确之道。在郑丽文看来，此次赴大陆参访反映出台湾主流民意的殷殷期盼。 郑丽文此行将走访江苏、上海、北京，每一站都蕴含深意。江苏是两地共同历史记忆和情感纽带的重要省份。此站意在缅怀历史、增进情感认同，强化两岸同根同源的民族情感与历史联结；作为祖国大陆的经济中心，上海不仅是两岸经贸往来的重要城市，也是两岸人员往来最频繁的城市。郑丽文访问上海，有助于倾听在沪台胞、台商、台青的真实心声，对于国民党未来如何在推动两岸融合发展中发挥积极作用，提供有力参考；「九二共识」始终是两岸关系的定盘星。此行压轴安排在北京，体现了政治高度。如果参照 2005 年连战率团来访时的行程，国共两党高层很大可能会在北京，就基于坚持「九二共识」、反对「台独」的共同政治基础，推动两党关系和两岸关系和平发展等议题交换意见。 郑丽文此次访问能够顺利成行，得益于国共两党长期以来积淀的政治互信以及持续不断的交流交往。党的十八大以来，在坚持一个中国原则和「九二共识」的共同政治基础上，国共两党保持良性互动，持续为两岸和平发展注入正能量。而郑丽文自当选中国国民党主席以来，多次强调坚持「九二共识」、反对「台独」的立场，并表达希望推动两岸交流、访问大陆的意愿，这也代表了台湾最新的主流民意。今年 2 月在北京举行的国共两党智库论坛，也为促成此访创造了良好条件。 距离郑丽文上次来到祖国大陆已时隔 20 余年。相信通过此访，郑丽文会直观看到，如今的祖国大陆，正在全面建设社会主义现代化强国、实现中华民族伟大复兴的征程上阔步前行。而当郑丽文亲眼见证祖国大陆全面发展的真实景象后，她和台湾同胞必将更加深刻地感悟到：作为中国人的志气、骨气、底气。 中国国民党主席时隔 10 年再次率团访问大陆，是新形势下国共两党交流对话的重要一环，符合两岸关系发展需要，符合两岸同胞共同愿望，符合中华民族根本利益。此访也必将再次让世界看清事实：两岸都是中国人、是一家人。两岸的事当然也应该由家里人商量着办。两岸中国人完全有智慧、有能力解决好自己的事情，守护好、建设好自己的家园。"}, "image_area": {"url": "https://pic1.zhimg.com/50/v2-ed433b32738d6d1c7dd6dfd66b2c4770_b.jpg"}, "metrics_area": {"text": "80 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2024796035973662135"}}, "attached_info": "CkkI5Nvx9+KhrpwPEAMaCTExOTA0OTk4MSCh2NHOBjAAOCZAF3ITMjAyNDc5NjAzNTk3MzY2MjEzNXgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "24_1775538619.58514", "card_id": "Q_7756984301", "feed_specific": {"answer_count": 33}, "target": {"title_area": {"text": "《天龙八部》中如何对丁春秋的武功进行定位？"}, "excerpt_area": {"text": "有人看不上丁春秋，因为他连游坦之都打不过。也有人觉得他的武功深不可测，那么他的武功到底是什么层次？"}, "image_area": {"url": "https://picx.zhimg.com/80/v2-4977264c6ddddb87b25fbce6ca59fa22_720w.webp?source=1def8aca"}, "metrics_area": {"text": "69 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/7756984301"}}, "attached_info": "CkAI5Nvx9+KhrpwPEAMaCTExMjUyNzkwMiDR/aq7BjAAODJAGHIKNzc1Njk4NDMwMXgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "25_1775538619.58962", "card_id": "Q_2023159993633896301", "feed_specific": {"answer_count": 32}, "target": {"title_area": {"text": "如何看待起点三万均作者找编剧付费学习？"}, "excerpt_area": {"text": "只能说人挺敬业的，更新字数不少，还在发愁写作方向人物塑造等等问题 但这不应该是编辑的活儿吗？ 三万均了责编不该稍微关注一下吗？"}, "image_area": {"url": "https://pic3.zhimg.com/v2-1e917a09aa0e8a3b98b181122c5de4a0_1440w.jpg"}, "metrics_area": {"text": "68 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2023159993633896301"}}, "attached_info": "CkkI5Nvx9+KhrpwPEAMaCTExOTAwMDU3NyDy8LnOBjAAOERAGXITMjAyMzE1OTk5MzYzMzg5NjMwMXgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_t