e_area": {"url": "https://pic1.zhimg.com/v2-76ae20c2673d441d62e9ebf5129118bd_1440w.jpg?source=7e7ef6e2&needBackground=1"}, "metrics_area": {"text": "64 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/658348543"}}, "attached_info": "CkAIxs/AgZiYqfZ2EAMaCTEwODU3NzcwOCCClIyzBjAAOKMDQBRyCTY1ODM0ODU0M3gAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "21_1775511507.231055", "card_id": "Q_2024413032667772670", "feed_specific": {"answer_count": 212}, "target": {"title_area": {"text": "妈妈不知儿子去世跟 AI 儿子聊了 1 年，AI「复活」逝者的服务有伦理风险吗？如果是你，会更愿意知道真相吗？"}, "excerpt_area": {"text": "#妈妈不知儿子去世跟 AI 儿子聊了 1 年#【#AI 复活 9 岁女儿在数据世界读书学习#】 「我是一个骗人感情的骗子。」 90 后 AI 修复者张泽伟这么形容自己。他用生成式 AI 技术「复活」逝者，通过还原逝者的相貌、声音、话语，塑造出一个可互动的「数字生命」。 在张泽伟的客户里，有人因父亲去世，为让奶奶安心生活，决定用 AI 生成的儿子给老人打视频，让老人能活下去；有人生成了 9 岁女儿的 AI 复原，在 AI 世界里，帮她设定好了未来的成长轨迹，包括读什么书，穿什么衣服、学什么新的技能...；也有因为爸爸离世患上抑郁症，在爸爸被 AI 复原以后走出来的孩子。 然而，被复原的，究竟是谁？到底是逝者，还是带着生者情感指向的存在？张泽伟聊起这个话题，他用了电影《破·地狱》里的一句话：破地狱破的到底是谁的地狱？破的是活人的地狱。"}, "image_area": {"url": "https://pic1.zhimg.com/v2-3313211644f775e9d895a41fd5ecacee.png"}, "metrics_area": {"text": "59 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2024413032667772670"}}, "attached_info": "CkoIxs/AgZiYqfZ2EAMaCTExOTAzODAzMiDujszOBjAAOMMFQBVyEzIwMjQ0MTMwMzI2Njc3NzI2NzB4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "22_1775511507.231731", "card_id": "Q_513191303", "feed_specific": {"answer_count": 28}, "target": {"title_area": {"text": "如果人类乘坐宇宙飞船 1 秒能飞行 1 光年 ，那人类要多久可以抵达宇宙边缘？"}, "excerpt_area": {"text": ""}, "image_area": {"url": "https://pic3.zhimg.com/50/v2-dd39651bf286218db4846486f9d90644_b.jpg"}, "metrics_area": {"text": "57 万热度", "font_color": "", "backgroun