。对于刚毕业或刚到陌生城市工作的人来说，也可能面临独居的孤独感和安全问题。 第一次租房时，究竟应该先选择性价比更高的合租房，把它当作适应城市生活的过渡；还是一步到位住单身公寓，为隐私和生活质量多花一些钱？你当时是怎么选择的，后来有没有后悔？"}, "image_area": {"url": "https://picx.zhimg.com/50/v2-366ccc52ced0ac2812a07d8bd4ed9595_b.jpg"}, "metrics_area": {"text": "60 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/12733180158"}}, "attached_info": "CkEIwNitzumWj8tEEAMaCTExMzUyMjMxNSCs/9a9BjAAOC5AHXILMTI3MzMxODAxNTh4AKoBCWJpbGxib2FyZNIBAA=="}], "paging": {"is_end": true, "is_start": false, "next": "", "previous": "", "totals": 0}, "fresh_text": "热榜已更新", "display_num": 15, "display_first": true, "fb_bill_main_rise": 0, "head_zone": {"type": "billboard_lantern", "data": [{"id": "1989780245977532317", "link_url": "https://www.zhihu.com/appview/community_construction", "title": " 辟谣专区", "source_type": 0, "attached_info": "Ci4QABoTMTk4OTc4MDI0NTk3NzUzMjMxN3ITMTk4OTc4MDI0NTk3NzUzMjMxN3gA", "tag": "辟谣", "tag_bg_color": "GRD01A"}]}, "head_zones": [{"type": "billboard_lantern", "data": [{"id": "1989780245977532317", "link_url": "https://www.zhihu.com/appview/community_construction", "title": " 辟谣专区", "source_type": 0, "attached_info": "Ci4QABoTMTk4OTc4MDI0NTk3NzUzMjMxN3ITMTk4OTc4MDI0NTk3NzUzMjMxN3gA", "tag": "辟谣", "tag_bg_color": "GRD01A"}]}]}