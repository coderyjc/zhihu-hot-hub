olor": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2018847286571058498"}}, "attached_info": "CkkI9vD33tSAt/E9EAMaCTExODg0OTE2MyDtj/vNBjAAOCFACXITMjAxODg0NzI4NjU3MTA1ODQ5OHgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "10_1774626829.754278", "card_id": "Q_2020636108078281987", "feed_specific": {"answer_count": 399}, "target": {"title_area": {"text": "伊朗称已组织超百万人为地面战斗做准备，这属于怎样的规模？美以伊真的会开启地面战争吗？"}, "excerpt_area": {"text": "总台记者获悉，当地时间 26 日，伊朗军方知情人士称，伊朗已组织超过一百万人为地面战斗做准备。 据悉，近几日大量伊朗青年向巴斯基民兵、伊朗伊斯兰革命卫队和陆军中心提交了参战申请。伊朗称已组织超百万人为地面战斗做准备"}, "image_area": {"url": "https://picx.zhimg.com/80/v2-0572870306fd35e91b6569c678bffa43_720w.webp?source=1def8aca"}, "metrics_area": {"text": "82 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2020636108078281987"}}, "attached_info": "CkoI9vD33tSAt/E9EAMaCTExODkxMzQ1NyDlk5XOBjAAONgGQApyEzIwMjA2MzYxMDgwNzgyODE5ODd4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "11_1774626829.754820", "card_id": "Q_2020252291693852352", "feed_specific": {"answer_count": 41}, "target": {"title_area": {"text": "如何评价《原神》「『空月之歌·旋舞』逢归的谶羽」月之六版本前瞻特别节目？"}, "excerpt_area": {"text": "2026 年 3 月 25 日中午，《原神》官方账号发布特别节目预告，宣布《原神》「『空月之歌·旋舞』逢归的谶羽」月之六版本前瞻特别节目将于 3 月 27 日（周五）20:00 正式开启："}, "image_area": {"url": "https://pica.zhimg.com/80/v2-c9ae98a1ab3f7055c51413ea0ac61665_1440w.webp?source=1def8aca"}, "metrics_area": {"text": "82 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2020252291693852352"}}, "attached_info": "CkkI9vD33tSAt/E9EAMaCTExODg5OTAyNiDwyI/OBjAAOD5AC3ITMjAyMDI1MjI5MTY5Mzg1MjM1MngAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "12_1774626829.755320", "card_id": "Q_2007677186740615086", "card_label": {"type": "new", "icon": "https://pic2.zhimg.com/80/v2-a4b0b52b561281109c51e4957cb20130_1440w.png", "night_icon": "https://pic3.zhimg.com/80/v2-10ef6526c602e55a8c606e46aa0cc586_1440w.png"}, "feed_specific": {"answer_count": 20}, "target": {"title_area": {"text": "打虎将李忠真的很小气吗？"}, "excerpt_area": {"text": "《水浒传》里的打虎将李忠，只因为在鲁达向他借银子资助金翠莲父女时，由于只出了二两银子而被鲁达骂做不爽利。也因为鲁达的这个评语而让很多读者也认为他很小气。请问李忠真的很小气吗？"}, "image_area": {"url": ""}, "metrics_area": {"text": "68 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2007677186740615086"}}, "attached_info": "CkkI9vD33tSAt/E9EAMaCTExODQ3MzEwOSD2ydjMBjAAOBpADHITMjAwNzY3NzE4Njc0MDYxNTA4NngAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "13_1774626829.756063", "card_id": "Q_2020440595139621906", "feed_specific": {"answer_count": 101}, "target": {"title_area": {"text": "拼多多官宣的「新拼姆」是什么？如何看待其「三年再造一个拼多多」的目标？"}, "excerpt_area": {"text": "3 月 25 日，拼多多集团正式宣布组建「新拼姆」，开启品牌自营，继续重仓中国供应链。 这是去年 12 月赵佳臻出任集团联席董事长兼联席 CEO 后，发布的首个重磅举措。赵佳臻此前宣布了「聚焦、重投供应链升级，高质量发展」的下阶段集团战略，提出「力争三年再造一个拼多多」。 据介绍，「新拼姆」已在上海成立新的专项公司，一期已现金注资 150 亿元，未来三年计划总计投入 1000 亿元真金白银，整合「拼多多 +Temu」的供应链资源，开启搭建自营品牌模式，重点面向全球市场，系统性自营并孵化面向不同市场、不同品类的品牌，实现中国制造高标准输出，推动中国制造进一步走向价值高端。（来源：界面新闻）拼多多宣布在上海组建「新拼姆」：重磅开启品牌自营，一期已注资 150 亿元"}, "image_area": {"url": "https://pic1.zhimg.com/50/v2-2fd3d5261bd727e3b7faf359dd44ae14_b.jpg"}, "metrics_area": {"text": "67 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2020440595139621906"}}, "attached_info": "CkoI9vD33tSAt/E9EAMaCTExODkwMzMzNyDPp5LOBjAAOMQCQA1yEzIwMjA0NDA1OTUxMzk2Mj