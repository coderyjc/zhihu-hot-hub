ttps://picx.zhimg.com/v2-2398010e42456e89017bba869bae5030.png"}, "metrics_area": {"text": "55 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2014274934000613195"}}, "attached_info": "CkoIkKr9jcncmJlfEAMaCTExODY4Mzk3NyCXy7jNBjAAOJkBQBdyEzIwMTQyNzQ5MzQwMDA2MTMxOTV4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "24_1773082487.717199", "card_id": "Q_2010212483034531395", "feed_specific": {"answer_count": 37}, "target": {"title_area": {"text": "考试成绩与科研能力之间存在着什么联系？"}, "excerpt_area": {"text": "题主今年大四即将毕业，未来想进入科研领域工作。最近一直在思考一个问题：许多人进入科研领域的敲门砖是自己优异的成绩，这些成绩往往是以考试的形式进行评分的。然而真实的科研却和考试有很大的区别。不可否认的是成绩优秀的人似乎更可能科研出成果，但我总觉得两者之间存在一种矛盾：考试是要在有限的时间里去复现自己烂熟于心的知识和套路，这种急功近利的状态我认为是与科研相悖的：即便天才也需要时间去思考去推演去检查自己的研究成果，其背后也未必存在一个「正确答案」。所以我的问题是：在成绩超过某一个临界点后，成绩的高低是否会与科研能力呈负相关？（抱歉在车上写的问题描述有些粗糙）"}, "image_area": {"url": "https://pic1.zhimg.com/v2-482c62c84353e27eea09a22e0db24d35_xl.jpg?source=57bbeac9"}, "metrics_area": {"text": "54 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2010212483034531395"}}, "attached_info": "CkkIkKr9jcncmJlfEAMaCTExODU0NTg5MyCjvP3MBjAAOFdAGHITMjAxMDIxMjQ4MzAzNDUzMTM5NXgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "25_1773082487.717800", "card_id": "Q_635818335", "feed_specific": {"answer_count": 46}, "target": {"title_area": {"text": "领导喜欢什么样子的下属？"}, "excerpt_area": {"text": "你会根据领导的喜好调整自己的处事方式吗？"}, "image_area": {"url": "https://picx.zhimg.com/v2-38ca362258f625a0555e5b4eeec24afe_xl.jpg?source=57bbeac9"}, "metrics_area": {"text": "53 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "