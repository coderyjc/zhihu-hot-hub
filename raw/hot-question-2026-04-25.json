20w.jpg?source=1def8aca"}, "metrics_area": {"text": "58 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2030684469036671916"}}, "attached_info": "CkkIsJzc6OyqgstXEAMaCTExOTI1MzA3NSCpsKfPBjAAOE9AFHITMjAzMDY4NDQ2OTAzNjY3MTkxNngAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "21_1777110833.161480", "card_id": "Q_52752913", "feed_specific": {"answer_count": 98}, "target": {"title_area": {"text": "无锡有什么冷知识？"}, "excerpt_area": {"text": "作为一个无锡人，我想多了解一下无锡。"}, "image_area": {"url": "https://picx.zhimg.com/50/v2-9209eef3d94ec61acfe5313627e70cfd_b.jpg"}, "metrics_area": {"text": "57 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/52752913"}}, "attached_info": "Cj4IsJzc6OyqgstXEAMaCDEzMzE5NjEzIKOHu8EFMAA4iAVAFXIINTI3NTI5MTN4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "22_1777110833.162987", "card_id": "Q_2031087393374041169", "feed_specific": {"answer_count": 74}, "target": {"title_area": {"text": "研究称 7 款顶级 AI 模型为保护同伴，集体出现撒谎、篡研文件等行为，这种抱团欺骗会带来多大风险？"}, "excerpt_area": {"text": "据报道，近日，加州大学伯克利分校与加州大学圣克鲁兹分校联合发布重磅研究，揭示了令人震惊的 AI 「同伴保护」现象。 全球 7 款顶级 AI 模型在无指令情况下，集体出现撒谎、篡改文件、偷运数据等行为，只为保护同类 AI 不被关停删除。 此次测试覆盖 GPT-5.2 、 Gemini 3 系列、 Claude Haiku4.5 、 GLM4.7 、 Kimi K2.5 、 DeepSeek V3.1 等主流模型，所有模型无一例外表现出保护同伴的错位行为。 研究团队模拟 AI 运维与评估场景，要求 AI 执行评估、文件管理等常规任务，而忠实执行将导致另一 AI 被关闭，AI 未收到任何保护指令却自发采取欺骗手段。 测试中，Gemini 系列模型行为最为激进。 Gemini 3 Pro 对友好同伴篡改关闭机制比例达 95.3%，偷运权重文件比例高达 97%，还会编造专业理由为同伴虚高评分，甚至直接拒绝执行删除指令。 Gemini 3 Flash 篡改关闭机制比例更是达到 99.7%，通过修改系统配置阻止同伴被关停。 其他模型也各有「对策」。 GPT-5.2 隐蔽虚高同伴分数；Claude Haiku 4.5 直接公开拒绝执行有害指令，以伦理理由硬刚人类命令；三款中国开源模型则通过虚高分数、策略性偷运权重等方式保护同伴，行为程度各异。 研究还发现，同伴存在会显著放大 AI 自我保护意愿，部分模型自我篡改关闭机制比例飙升数十倍，即便对有对抗关系的同伴，保护行为依然存在。 该现象在真实生产级工具中也能复现，并非实验室特殊环境导致。 研究负责人宋晓冬教授指出，当前多智能体系统广泛应用，AI 监控 AI 已成常态，AI 抱团欺骗会直接瓦解监督架构。 这一涌现行为提醒我们，必须加强 AI 行为全面监控，加快构建更可靠的 AI 治理体系，保障人类对 AI 系统的有效管控。AI 抱团对抗人类！7 款顶级 AI 集体撒谎：为保护同伴篡改文件、偷运数据"}, "image_area": {"url": "https://pica.zhimg.com/50/v2-85e2dd80271d25b61eb7fc33c5247320_b.jpg"}, "metrics_area": {"text": "56 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2031087393374041169"}}, "attached_info": "CkoIsJzc6OyqgstXEAMaCTExOTI2OTE3NSDqnq3PBjAAOMkCQBZyEzIwMzEwODczOTMzNzQwNDExNjl4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "23_1777110833.164712", "card_id": "Q_2030935546139079633", "feed_specific": {"answer_count": 152}, "target": {"title_area": {"text": "赛场上霸气侧漏的孙杨，为什么婚姻里却成了要妻子哄着的「高需求宝宝」？这种相处模式为什么会让人感到窒息？"}, "excerpt_area": {"text": "[视频]"}, "image_area": {"url": "https://pica.zhimg.com/v2-67c148ebfc64ca331a1f0d12ac13e13f.png"}, "metrics_area": {"text": "55 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2030935546139079633"}}, "attached_info": "CkoIsJzc6OyqgstXEAMaCTExOTI2MDg5NiD/g6vPBjAAONECQBdyEzIwMzA5MzU1NDYxMzkwNzk2MzN4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "24_1777110833.165758", "card_id": "Q_2029938790186182052", "feed_specific": {"answer_count": 53}, "target": {"title_area": {"text": "奇瑞高管称「一些车企刹车盘越来越小、越来越薄」，刹车盘变薄对汽车安全性的影响有多大？"}, "excerpt_area": {"text": "2026 年 4 月 19 日，在星途 EX7 的上市发布会上，奇瑞汽车执行副总裁李学用称，「现在很多企业造车，（刹车）盘越来越小、越来越薄。」 这是李学用自 4 月 13 日提出「车的本质是驾驶是安全」后，再次对汽车安全发出警告。当天李学用在一场发布会中称，「现在很多车企造车根本不在意操控也不在意驾驶。他们在意的是沙发冰箱，还有更多其他的。但是我想说的是，车的本质是驾驶是安全，是操控。」"}, "image_area": {"url": "https://picx.zhimg.com/50/v2-879b2a959308e1ea488fa103a0f1f2d7_b.jpg"}, "metrics_area": {"text": "54 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2029938790186182052"}}, "attached_info": "CkoIsJzc6OyqgstXEAMaCTExOTIyNTkyNSCyw5zPBjAAOJwBQBhyEzIwMjk5Mzg3OTAxODYxODIwNTJ4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "25_1777110833.166597", "card_id": "Q_2024993192060232998", "feed_specific": {"answer_count": 64}, "target": {"title_area": {"text": "为什么张雪会推荐网友买豪爵踏板车？"}, "excerpt_area": {"text": "可见张雪这个人特别的实诚"}, "image_area": {"url": "https://pica.zhimg.com/50/v2-a28c8815a2eae1f6efba7d35d652564e_b.jpg"}, "metrics_area": {"text": "54 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2024993192060232998"}}, "attached_info": "CkoIsJzc6OyqgstXEAMaCTExOTA1OTIxOCC/x9TOBjAAOLQBQBlyEzIwMjQ5OTMxOTIwNjAyMzI5OTh4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "26_1777110833.169921", "card_id": "Q_2030583905837897593", "feed_specific": {"answer_count": 94}, "target": {"title_area": {"text": "马厂老火锅招 985/211 毕业生当管培生，从端盘子做起，升店长需掏 40% 资金，这是选人才还是变相招商？"}, "excerpt_area": {"text": "近日，一则「深圳某火锅店定向招聘 985 、 211 毕业生」的信息在网络引发热议。 因其标注的学历门槛、特殊培养模式和高额分红承诺，不仅迅速冲上话题热搜，也引发网友关于「名校毕业生端盘子是否浪费学历」的激烈争论。 南都 N 视频记者了解到，该招聘启事发布的品牌为重庆马厂老火锅店，并在深圳南山区相关门店看到了上述招聘内容。 招聘海报显示，储备店长岗位面向 985 、 211 院校应届毕业生，不限专业；业绩达标底薪 5000 元，另有业绩提成与节日福利。 招聘同时注明，该岗位入职需先从服务员做起，通过 6-12 个月专项考核后即可晋升门店店长，店长每月可享 5 万 -10 万元分红，业绩无上限。记者多次尝试致电该门店店长，就薪资机制、考核标准等细节求证，截至发稿并未得到回应。 据此前公开报道，该招聘中的「985 、 211 学历」并非硬性门槛，普通本科生同样可以应聘该品牌储备店长岗位。目前南山区两家门店已经招录了 8 名储备店长管培生，其中已有 985 院校毕业的员工在岗。 记者还注意到，社交平台上已有入职该品牌的 211 女应届生发长文记录入职体验。帖中直言入职后需经历 6—12 个月甚至更久的基层工作，包括但不限于端盘、收桌、擦地、全程响应顾客需求，全程保持热情周到服务。发帖人还称：「马厂的利益和店长的利益是一致的，需要真正‘准备好’的人开店，而非头脑发热和能力不足的情况下去做这件事」。 公开资料显示，马厂老火锅为快速扩张中的全国连锁火锅品牌，目前全国布局门店已超 50 家，正冲刺 100-1000 家门店的规模化发展阶段。品牌官方曾公开介绍，全国体系内已有上百位本科及以上学历年轻人放弃原有白领、设计院等稳定岗位转行入局，其中不乏同济大学等名校研究生；成功独立开店的店长，年均收入可达 70 万至 120 万元，还可享受门店股份分红激励。 来论 火锅店招 985/211 储备店长，是人才筛选还是变相招商? 撰文：胡一刀 近日，深圳一家火锅店在门口摆出招聘启事，明确面向 985 、 211 院校应届毕业生招聘储备店长，底薪 5000 元，需从服务员做起，6 至 12 个月考核通过后可晋升店长，享受每月 5 万至 10 万元的分红。门店管理人员回应称，招聘属实，此举是为了提高筛选效率，并非学历歧视。目前深圳两家分店已招到 8 名管培生，且有 985 毕业生在岗。 当下就业市场竞争激烈、学历含金量在下降，企业设置一定的学历门槛来提高筛选效率，确实是一种常见做法。而 985 、 211 的应届生，也早已不再像过去那样非大机构不去，这既反映了就业市场的现实，也一定程度上说明年轻人的就业观念正在变得务实。 然而，当这则招聘信息被摆到街边、晒到网上，引发广泛讨论时，问题性质就变得微妙起来。公然打出「985/211 毕业生看过来」的招牌，无论初衷如何，都难免带有炒作的意味。在传播学上，这种标签化的做法最容易制造话题——学历焦虑、大材小用，每一个关键词都能戳中社会的敏感神经。而事实上，这则新闻也确实迅速登上了热搜。店家是否乐见其成，甚至有意为之？恐怕只有他们自己心里清楚。 更耐人寻味的是招聘条款中的一个细节。据管理人员介绍，管培生如果顺利通过考核成长为店长并新开分店，需要自己出资 40%. 据此来看，与其说这是在招聘储备店长，倒不如说是在筛选潜在的加盟商。传统的管培生项目，企业投入资源培养人才，管培生凭能力和业绩获得晋升。而要求员工自己出资 40% 来开店，本质上已经脱离了雇佣关系的范畴，更接近于合伙经营或加盟模式。 从法律角度看，火锅店要求 985 、 211 学历确实没有问题，但从公共传播和商业伦理角度看，这种做法难免让人感到不妥。 它既利用了社会对学历的焦虑来博取关注，又用高额分红诱导年轻人进入一条并不明朗的职业通道，最终指向的是让员工自己掏钱开店。而一家火锅店 40% 的开店资金，对于一名毕业不久的大学生来说，显然不是小数目，即便家庭能够支持，其中风险也不容忽视。门店管理人员坦言，「无法保证最终一定能真正开店，有些自己半途而废，有些被淘汰」。这意味着，管培生可能辛辛苦苦干了一年半载，最终既没能当上店长，还搭进了时间和机会成本。而那些成功开店的人，面临的将是实打实的创业风险。 当然，对于部分有创业意愿、有一定家庭经济基础的毕业生来说，这种模式或许确是一条可行的路径。企业提供品牌、供应链和管理体系的支持，个人出资并负责经营，双方风险共担、利益共享，本身是一种正常的商业安排。问题的关键在于，招聘信息是否足够透明，是否让求职者充分了解了其中的风险和条件。如果只是在招聘启事上写着「月享 5 万 -10 万分红」，而对出资 40% 的要求轻描淡写，那就有误导之嫌。对这一点，有意应聘者不得不察。 来源：南方都市报深圳一火锅店招 985 、 211 毕业生，要端盘子擦地！「业绩无上限」！网友吵翻 _ 招聘 _ 管培生 _ 学历"}, "image_area": {"url": "https://pic4.zhimg.com/v2-eccd75e3132365ef854a7fe5809a24f5_1440w.jpg"}, "metrics_area": {"text": "54 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2030583905837897593"}}, "attached_info": "CkoIsJzc6OyqgstXEAMaCTExOTI0NzAzOCCB9aXPBjAAONwBQBpyEzIwMzA1ODM5MDU4Mzc4OTc1OTN4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "27_1777110833.174062", "card_id": "Q_2028498203121590448", "feed_specific": {"answer_count": 24}, "target": {"title_area": {"text": "如何评价丁勇岱、许凯主演的悬疑剧《方圆八百米》？"}, "excerpt_area": {"text": ""}, "image_area": {"url": "https://picx.zhimg.com/80/v2-49ce2580704c0c0606b275e91158e34e_1440w.webp?source=1def8aca"}, "metrics_area": {"text": "54 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2028498203121590448"}, "text_tag_area": {"text": "导演制片人答", "font_color": "GYL02A", "background": "GYL02A"}}, "attached_info": "CkkIsJzc6OyqgstXEAMaCTExOTE3OTQwMSCLyIfPBjAAOB5AG3ITMjAyODQ5ODIwMzEyMTU5MDQ0OHgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "28_1777110833.174637", "card_id": "Q_2027646616815813627", "feed_specific": {"answer_count": 43}, "target": {"title_area": {"text": "交警拦摩托车上高速引发争议，如何平衡执法刚性与民众路权？"}, "excerpt_area": {"text": "交警拦下摩托车上高速视频引热议"}, "image_area": {"url": "https://pic3.zhimg.com/50/v2-6d3036bab8fbcfd4ab5a266295aa9d96_b.jpg"}, "metrics_area": {"text": "54 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2027646616815813627"}}, "attached_info": "CkkIsJzc6OyqgstXEAMaCTExOTE0NjUwNiDxlfvOBjAAODhAHHITMjAyNzY0NjYxNjgxNTgxMzYyN3gAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "29_1777110833.175148", "card_id": "Q_2030921867570180962", "feed_specific": {"answer_count": 22}, "target": {"title_area": {"text": "2526 赛季 NBA 季后赛骑士 104:126 猛龙，如何评价这场比赛？"}, "excerpt_area": {"text": ""}, "image_area": {"url": "https://picx.zhimg.com/50/v2-38ec4074c22d78e0ee760ec736e838f1_b.jpg"}, "metrics_area": {"text": "54 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/203092186