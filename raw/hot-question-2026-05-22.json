 的主张，同时通过更可靠的指标来衡量 AI 市场的吸引力与风险。Token 消耗是衡量 AI 市场领导力的误导性指标"}, "image_area": {"url": "https://pic2.zhimg.com/50/v2-244647a41da5f58ecf951c6896c05bf3_b.jpg"}, "metrics_area": {"text": "57 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2037866976014328423"}}, "attached_info": "CkkIuZbqmrCqu/0rEAMaCTExOTQ5MDEyNSDk8o/QBjAAOB5AHXITMjAzNzg2Njk3NjAxNDMyODQyM3gAqgEJYmlsbGJvYXJk0gEA"}], "paging": {"is_end": true, "is_start": false, "next": "", "previous": "", "totals": 0}, "fresh_text": "热榜已更新", "display_num": 15, "display_first": true, "fb_bill_main_rise": 0, "head_zone": {"type": "billboard_lantern", "data": [{"id": "2041106624878752401", "link_url": "https://zhuanlan.zhihu.com/p/2041079110978560567?share_code=19JRcKjT4OWBb&utm_psn=2041101666775193192", "title": "净网|网警查处拍摄到“野生华南虎”谣言", "source_type": 0, "attached_info": "Ci4QABoTMjA0MTEwNjYyNDg3ODc1MjQwMXITMjA0MTEwNjYyNDg3ODc1MjQwMXgA", "tag": "关注", "tag_bg_color": "GRD01A"}, {"id": "2039698611253065372", "link_url": "https://v.wjx.cn/vm/rX3KUAM.aspx", "title": "事关结婚生娃！这份问卷等您来参与", "source_type": 0, "attached_info": "Ci4QABoTMjAzOTY5ODYxMTI1MzA2NTM3MnITMjAzOTY5ODYxMTI1MzA2NTM3MngA", "tag": "关注", "tag_bg_color": "GYL01A"}, {"id": "1989780245977532317", "link_url": "https://www.zhihu.com/appview/community_construction", "title": "辟谣专区", "source_type": 0, "attached_info": "Ci4QABoTMTk4OTc4MDI0NTk3NzUzMjMxN3ITMTk4OTc4MDI0NTk3NzUzMjMxN3gA", "tag": "辟谣", "tag_bg_color": "GRD01A"}]}, "head_zones": [{"type": "billboard_lantern", "data": [{"id": "2041106624878752401", "link_url": "https://zhuanlan.zhihu.com/p/2041079110978560567?share_code=19JRcKjT4OWBb&utm_psn=2041101666775193192", "title": "净网|网警查处拍摄到“野生华南虎”谣言", "source_type": 0, "attached_info": "Ci4QABoTMjA0MTEwNjYyNDg3ODc1MjQwMXITMjA0MTEwNjYyNDg3ODc1MjQwMXgA", "tag": "关注", "tag_bg_color": "GRD01A"}, {"id": "2039698611253065372"