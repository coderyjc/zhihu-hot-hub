87e52f010bb5e7d773_1440w.png"}, "feed_specific": {"answer_count": 37}, "target": {"title_area": {"text": "大家周末加班了，老板说让我给办公室的人都去买盒饭，我买了小碗菜，被批评了请问正常不？"}, "excerpt_area": {"text": "理由是去迟了，平时那家卖盒饭的盒饭卖完了，所以我去旁边买了小碗菜，预算是 15 元 / 人，所以我就平均一人分一份饭一个菜，平均每个菜 12.8 元，米饭 1 元。 而领导的意思是我应该把菜提前给每个人分好，这样大家想吃不同的菜就不需要坐在一起可以各吃各的，请问大家怎么看？"}, "image_area": {"url": "https://picx.zhimg.com/v2-0efae158a56a88ef854a5edb1edad9d4.png"}, "metrics_area": {"text": "91 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2042576689323037760"}}, "attached_info": "CkkI8oym/+qC7Yh6EAMaCTExOTY3NjA4OSCnt9TQBjAAOE5AC3ITMjA0MjU3NjY4OTMyMzAzNzc2MHgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "12_1780008093.310703", "card_id": "Q_2043264595666658269", "card_label": {"type": "hot", "icon": "https://pic2.zhimg.com/80/v2-266e83dbee46dce23b718e0531cb7d3a_1440w.png", "night_icon": "https://pic3.zhimg.com/80/v2-c89199839c237b87e52f010bb5e7d773_1440w.png"}, "feed_specific": {"answer_count": 36}, "target": {"title_area": {"text": "如何看待蔚来 「突袭式」 发布新款，成都提车 9 天变旧款，车主称遭遇「背刺」？你怎么看？"}, "excerpt_area": {"text": "据媒体报道，蔚来 4 月 7 日正式发布 2026 款萤火虫车型，新增多项配置。多位近期购车的车主，因车企未提前公示、告知新款上市信息，刚提车就面临车辆贬值和配置落后的双重损失。其高管公开承认 「通知太晚是个小错误」，至今未给出实质性补偿，目前已有 60 多位车主组队维权，要求合理补偿。消费者面临类似事件合法权益该如何得到保障？这种突袭发布新车的是否应该提前告知消费者？是否应该由消费者承担全部后果？ 新闻报道链接：%3D%3D_5303132680619204_s&s_channel=4"}, "image_area": {"url": "https://pica.zhimg.com/v2-3e8ff704a1333790431915526e0be55a.png"}, "metrics_area": {"text": "88 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2043264595666658269"}}, "attached_info": "CkkI8oym/+qC7Yh6EAMaCTExOTcwMzM0OCDRuN7QBjAAOE9ADHITMjA0MzI2NDU5NTY2NjY1ODI2OXgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "13_1780008093.312466", "card_id": "Q_2043314967013581849", "card_label": {"type": "hot", "icon": "https://pic2.zhimg.com/80/v2-266e83dbee46dce23b718e0531cb7d3a_1440w.png", "night_icon": "https://pic3.zhimg.com/80/v2-c89199839c237b87e52f010bb5e7d773_1440w.png"}, "feed_specific": {"answer_count": 88}, "target": {"title_area": {"text": "5 月 28 日现货黄金跳水，盘中跌破 4400 美元 / 盎司，受到哪些因素影响？还会持续下跌吗？"}, "excerpt_area": {"text": "28 日早间，现货黄金跳水，盘中跌破 4400 美元 / 盎司，现跌超 1%。 消息面上，据新华社，伊朗塔斯尼姆通讯社 28 日援引一名军方消息人士的话称，4 艘船只试图未经许可通过霍尔木兹海峡，在遭到伊朗海军鸣枪示警后被迫返航。"}, "image_area": {"url": "https://pic1.zhimg.com/v2-5c395b81d2a3a8e0171314bd56191908_1440w.jpg"}, "metrics_area": {"text": "87 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2043314967013581849"}}, "attached_info": "CkoI8oym/+qC7Yh6EAMaCTExOTcwNzM5NiC7lt/QBjAAOLICQA1yEzIwNDMzMTQ5NjcwMTM1ODE4NDl4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "14_1780008093.314103", "card_id": "Q_2043099859129983602", "card_label": {"type": "hot", "icon": "https://pic2.zhimg.com/80/v2-266e83dbee46dce23b718e0531cb7d3a_1440w.png", "night_icon": "https://pic3.zhimg.com/80/v2-c89199839c237b87e52f010bb5e7d773_1440w.png"}, "feed_specific": {"answer_count": 226}, "target": {"title_area": {"text": "法拉利首款纯电动车 Luce 首秀后，公司股价大跳水，前主席怒斥可以去掉跃马标，问题出在了哪里？"}, "excerpt_area": {"text": "跃马品牌在纯电动赛道上的起跳未能迎来预期中的喝彩声。 当地时间 5 月 26 日，法拉利米兰挂牌股价盘中大跌近 8%，最终跌幅收窄至 6% 以上；美东时间 5 月 26 日收盘，法拉利股价报 329.91 美元，跌幅为 5.25%。 消息面上，当地时间 5 月 25 日，意大利超跑制造商法拉利在罗马发布了品牌首款纯电动车型 Luce（在意大利语中意为「光」）。 据悉，该车由 LoveFrom 设计团队负责外观和内饰设计，并由位于马拉内罗的法拉利设计工作室提供技术支持。而 LoveFrom 设计团队的联合创始人是乔纳森·伊夫与马克·纽森，前者曾在苹果公司担任首席设计官。 据介绍，法拉利 Luce 彻底打破法拉利传统的双门跑车造型框架，采用四轮驱动系统及四门五座布局，这也是法拉利第二款四门车型。该车在意大利的起售价为 55 万欧元，约合人民币 435 万元，预计 2026 年第四季度在欧洲交付，2027 年第二季度开始在美国交付。 具体来看，新车车长超 5 米，车顶、侧窗与前挡风玻璃都采用大面积康宁玻璃材质，打造出「玻璃屋」造型，车尾延续法拉利经典的圆形尾灯设计。动力方面，该车由四个电动机驱动，最大功率为 1050 马力，零百加速 2.5 秒，最高时速 310 公里，满电续航里程为 530 公里，配备 122 千瓦时的电池组，采用 800 伏电气架构，整车重量为 2260 公斤。法拉利纯电动车首秀「翻车」？股价大跳水，分析师预警：品牌价值或面临受损风险 | 每经网"}, "image_area": {"url": "https://pica.zhimg.com/50/v2-1198b8479d876bedc2b4171e4b290f82_b.jpg"}, "metrics_area": {"text": "86 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2043099859129983602"}}, "attached_info": "CkoI8oym/+qC7Yh6EAMaCTExOTY5ODk3MCDlhdzQBjAAOJUDQA5yEzIwNDMwOTk4NTkxMjk5ODM2MDJ4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "15_1780008093.315169", "card_id": "Q_2042674181716669364", "feed_specific": {"answer_count": 33}, "target": {"title_area": {"text": "新能源车动辄 2 吨以上，有的接近 4 吨，为什么车企拼命把车做大、做重？这么重会有什么隐患？"}, "excerpt_area": {"text": "当「大冰箱、大彩电、大沙发」成为新车标配，当新能源车企以「越级尺寸」作为卖点，中国消费者似乎已经习惯了一个事实：新车越来越大了，也越来越重了。 工信部数据显示，2024 年我国乘用车新车平均整备质量已达 1704 公斤，而 2012 年这一数字仅为 1312 公斤。短短 12 年间，一辆普通家用车硬生生「胖」了近 400 公斤。更值得警惕的是，汽车增重速度正在加快：2020 年至 2024 年的增重幅度，已超过 2012 年至 2020 年八年的总和。新能源车尤甚，平均整备质量动辄超过 2 吨。2024 年，理想、赛力斯均超 2.4 吨，蔚来超 2.2 吨，小鹏超 2 吨。 2025 年的最新数据虽尚未公布，但从已露端倪的趋势看，新车「增肥」不容乐观。前不久，尊界两款车型登陆工信部，总质量均超 3 吨，其中尊界 V800 更是达到 3.8 吨——比一辆轻卡还重。 「这一变化可归因于大型 SUV 追捧导致的车身尺寸扩张、新能源车追求长续航带来的电池重量膨胀，以及冰箱、彩电、多功能超豪华座椅等配置的日益堆砌。」同济大学汽车学院教授韩志玉在接受第一财经记者采访时表示，随着新能源汽车渗透率快速提升，汽车「肥胖」现象愈发凸显。 然而，这场「增重」运动正遭受前所未有的质疑。韩志玉表示，车重持续攀升非但不是汽车工业进步的必然勋章，反而是行业无序竞争的结果之一，与节能减排、绿色环保的初衷背道而驰，更演变成一场关乎资源、环境与可持续发展的深刻悖论。 第一财经记者在采访中发现，业内人士普遍呼吁对汽车「增重」现象出台监管措施。多名受访者证实，相关监管部门已开始研讨以车重为计税依据的汽车税收制度改革。新能源车超重隐忧：4 吨的车来了，路快撑不住了"}, "image_area": {"url": ""}, "metrics_area": {"text": "83 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2042674181716669364"}}, "attached_info": "CkkI8oym/+qC7Yh6EAMaCTExOTY4MDgyNSDz7NXQBjAAOC9AD3ITMjA0MjY3NDE4MTcxNjY2OTM2NHgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "16_1780008093.316033", "card_id": "Q_2042897105346368773", "feed_specific": {"answer_count": 45}, "target": {"title_area": {"text": "香港拟将「中国内地」英译改为「Chinese Mainland」，此举释放了哪些信号？"}, "excerpt_area": {"text": "香港特区政府正检视法律条例中遗留的殖民色彩用语，包括将「中国内地」的英文翻译改为「Chinese Mainland」。 据香港《明报》26 日报道，香港律政司日前向立法会预告，将提交第三批成文法杂项修订书。律政司在给立法会司法及法律事务委员会的文件中说，由于建议属于技术性质及相对简单直接，特区政府计划在立法会本会期内尽快提交《2026 年成文法（杂项规定）条例草案》。文件重申，目前目标是争取在本届政府任期结束前，即明年 6 月 30 日完成法律适应化修改工作。 这是继 2024 年及 2025 年立法会通过类似修订后，香港特区政府第三批相关修订。报道称，本次修订涉及改动超过 120 条法例及附属法例，单海事法就涉及 30 多条法例。 报道举例称，除继续修订现行法例中「女皇陛下」，或将「总督」改为「行政长官」外，草案同时建议将「中国内地」的英文翻译「Mainland of China」改为「Chinese Mainland」，与内地官方翻译一致。相关改动将影响《深圳湾口岸港方口岸区（准许进入）公告》以及《西九文化区管理局条例》等 15 条主体及附属法例。 香港多个政策局也提出修改建议，例如运输及物流局建议在海事法例中删除提及「英国标准」或「英国法例」的字句，更新为国际标准。 此外，有关法律条文中「主权移交」的表述，也将修改为「中华人民共和国恢复对香港行使主权」。特区政府表示，这项修改旨在「准确反映《中英联合声明》宣布的内容」。持续「去殖」，香港拟再修订法律用语"}, "image_area": {"url": "https://pic1.zhimg.com/v2-2dbd485c1f5a29e2225c7d1f000a5b9b.png"}, "metrics_area": {"text": "80 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2042897105346368773"}}, "attached_info": "CkoI8oym/+qC7Yh6EAMaCTExOTY4NzY3NyCRjNnQBjAAOLMBQBByEzIwNDI4OTcxMDUzNDYzNjg3NzN4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "17_1780008093.316837", "card_id": "Q_389063678", "feed_specific": {"answer_count": 251}, "target": {"title_area": {"text": "《武林外传》中白展堂真的只会葵花点穴手吗，他的武功到底厉不厉害？"}, "excerpt_area": {"text": "看了好几遍武林外传，白展堂作为盗圣，为什么，让人只觉得他就会葵花点穴手。"}, "image_area": {"url": "https://pic1.zhimg.com/v2-e89068a624b13b24a03e10f147c6910b.png"}, "metrics_area": {"text": "77 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/389063678"}}, "att