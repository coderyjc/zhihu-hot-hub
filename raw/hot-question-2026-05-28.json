SDbsN7QBjAAOC9AEXITMjA0MzI2MDM0MTU1NTkxMzg4MngAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "18_1779939480.989880", "card_id": "Q_533875462", "feed_specific": {"answer_count": 38}, "target": {"title_area": {"text": "高考押题是智商税吗?"}, "excerpt_area": {"text": "马上高考了 天星教育和解题达人都出了押题卷 想问一下你们做过这两个出版社的 当年押中了吗 押题是智商税吗"}, "image_area": {"url": "https://pica.zhimg.com/80/v2-10a95dd2b6fc3b6fcc194f141c414bcc_720w.webp?source=1def8aca"}, "metrics_area": {"text": "109 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/533875462"}}, "attached_info": "Cj4I7MSgrL6ZwaJHEAMaCDgwOTIwNDE1IKbtoZQGMAA4PUAScgk1MzM4NzU0NjJ4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "19_1779939480.990246", "card_id": "Q_2043052117854613747", "feed_specific": {"answer_count": 38}, "target": {"title_area": {"text": "杭州非法代孕窝点称能选胎儿性别，女子十万移植失败又添新病，官方已立案调查，为何代孕屡禁不止？"}, "excerpt_area": {"text": "今天，浙江省杭州市临平区联合调查处置组发布情况通报。针对群众反映临平区某小区一住宅内有人非法从事试管婴儿手术问题，区委、区政府成立由卫健、公安等部门组成的联合调查处置组，详情如下。 浙江临平通报某小区住宅内有人非法从事试管婴儿手术：卫健部门已立案调查 5 月 26 日，杭州市民陈先生向大象新闻·大象帮爆料称，杭州临平区某别墅区内隐匿着一处非法试管婴儿胚胎实验室。该实验室无正规医疗资质，却大肆开展供卵、胚胎移植等违规助孕服务。 44 岁的备孕女性张女士不慎陷入骗局，花费十万元签约助孕套餐，历经两次违规移植均以失败告终，身体还新增了多项妇科病。5 月 26 日晚，记者实地采访调查时，遭现场人员暴力阻挠并受伤，涉事窝点已被临平区相关部门介入查处。 …记者暗访杭州别墅区代孕窝点：称可筛选胎儿性别，女子 10 万移植失败又添新病；多部门到场调查，胚胎师试图逃跑，女记者遭暴力拖拽骨折"}, "image_area": {"url": "https://picx.zhimg.com/80/v2-0e1e82788016d5e06c8f4e191d2860b8_720w.webp?source=1def8aca"}, "metrics_area": {"text": "108 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2043052117854613747"}}, "attached_info": "CkkI7MSgrL6ZwaJHEAMaCTExOTY5NjgwOSDurNvQBjAAOFdAE3ITMjA0MzA1MjExNzg1NDYxMzc0N3gAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "20_1779939480.991726", "card_id": "Q_2042868544048779888", "feed_specific": {"answer_count": 66}, "target": {"title_area": {"text": "不懂就问，华为为什么要公布韬定律，公开了那不是西方厂商也可以叠加做了？"}, "excerpt_area": {"text": "如题。"}, "image_area": {"url": "https://pica.zhimg.com/80/v2-f99a33101586fc8e7db11c8e4c3ebf2d_720w.webp?source=1def8aca"}, "metrics_area": {"text": "108 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2042868544048779888"}}, "attached_info": "CkkI7MSgrL6ZwaJHEAMaCTExOTY4NjU1NCD31tjQBjAAOGZAFHITMjA0Mjg2ODU0NDA0ODc3OTg4OHgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "21_1779939480.992439", "card_id": "Q_2042928866512065813", "feed_specific": {"answer_count": 42}, "target": {"title_area": {"text": "广东 2026 年高三 9 月 1 日开学，比往年惯例延迟一个月，引家长担忧，怎样看待这一调整？会影响高考备考吗？"}, "excerpt_area": {"text": "距离今年高考仅剩 10 天。当本届考生全力冲刺时，下届高三的开学时间，却成了舆论焦点。 5 月 26 日，广东省教育厅上线「民声热线」，有家长呼吁高三恢复 8 月 1 日开学。对此，有关负责人回应，今年高三 9 月 1 日开学，这项安排是非常慎重作出的决定。 一边是家长的「恢复」呼声，一边是部门的「慎重」定调，全省统一的高三延迟一个月开学，会影响高考备考吗？如何理性看待？ 01 高考时间的调整，始于天气考量。 1979 年至 2002 年，全国统一高考时间定在 7 月 7 日至 9 日。然而 7 月正值仲夏，考生赶考如同赶「烤」，有时还会遭遇台风、暴雨、洪涝等极端天气。这明显增加了高考的组织难度。 相较而言，6 月气温更低、湿度更小，出现极端天气的概率也相对较低。 于是，2001 年 11 月，教育部宣布从 2003 年起，高考时间由 7 月提前至 6 月。考试时间提前了，高三的开学时间也随之提前一个月。 今年，广东决定打破「惯例」—— 5 月中旬，广东 21 地市教育局相继发布新学年校历：高三开学不再「抢跑」，与其他年级一样定于 9 月 1 日，相比往年惯例的 8 月 1 日，延迟了一个月。 02 开学时间调整后，一些家长随之有了顾虑。 一是怕孩子「掉队」。高考是人生的一场大考。高三就像足球比赛中的「临门一脚」，最是扣人心弦，谁也不敢掉以轻心。对考生而言，这十余年「长跑」的最后一击能否踢得精彩，直接关系通往未来的大门。 二是怕有人「抢跑」。教育水平的差异客观存在。广东是教育大省，但发展不平衡不充分的问题突出，区域之间、校际之间存在差距。开学延迟了一个月，是否会有人「抢跑」？这也会制造新的不公平。 三是家里难「托底」。家庭的现实困难也不容忽视。可能有的家长忙于工作，无暇顾及孩子的假期学习。对他们来说，学校是专业机构，孩子在校远比在家放心。 盼着孩子好，是天下父母最朴素的心愿。这份心愿，可以理解。 当然，教育管理部门，也有自己的考量。 农历马年刚一开工，2 月 25 日，教育部举行深入落实「健康第一」工作部署会。会上强调，落实「健康第一」教育理念是落实立德树人根本任务、筑牢接班人身心根基的长远大计。 高三延迟开学，是落实「双减」政策、「健康第一」教育理念的题中之义。目前全国已有近 20 个省份将高三安排在 9 月 1 日开学，北京、上海、江苏、浙江等教育发达省份均在此列。 「去年年底国家发布的普通高中课程方案，对高三上课时间作出了明确规定。」省教育厅有关负责人表示，结合座谈会意见和国家建议， 高三延迟开学，影响高考吗？ 但首年延迟开学，一些细节仍需关注—— 可以说， 「升学率不是唯一的成绩，把孩子培养成身心健康的人，才是最大的本事。」正如省教育厅副厅长李璧亮所说，身体垮了，心理出问题了，再高的分数也是零。 内容来源广东高三延迟一个月开学，怎么看？怎么办？"}, "image_area": {"url": "https://pic2.zhimg.com/v2-2f8974c7195c728e3226111a1600a0ab_1440w.jpg"}, "metrics_area": {"text": "107 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2042928866512065813"}}, "attached_info": "CkkI7MSgrL6ZwaJHEAMaCTExOTY5MDMxMSClx9nQBjAAODlAFXITMjA0MjkyODg2NjUxMjA2NTgxM3gAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "22_1779939480.996530", "card_id": "Q_2042012458961695411", "feed_specific": {"answer_count": 34}, "target": {"title_area": {"text": "男子钓鱼捞起一溺水婴儿，目前孩子已平安从医院回到家，如何避免这种情况的发生？"}, "excerpt_area": {"text": "【#钓鱼佬救下溺水婴儿网友纷纷发红包##被钓鱼男子捞起婴儿已平安回家#】#男子钓鱼捞起一溺水婴儿#5 月 24 日，浙江慈溪，网友发帖称在河边钓鱼时，看见一个小女孩在岸边哭，低头发现一婴儿溺水，赶紧上前救人。 记者联系上发帖人，对方表示，视频发出后，收获了近百万点赞，还有许多网友向他转账发红包，都被他拒收了。因为不会溺水急救相关知识，救人大哥将孩子从水里抱起后，赶紧让孩子妈妈送去医院了。当晚 18 时 50 分，救人大哥再次发帖称：村里给他打了电话，孩子已经没事了，从医院回到家了。 男子钓鱼听见有哭声，低头一看水里飘着个婴儿，果断跳下水将其捞起，岸上家长焦急大哭 _ 腾讯新闻"}, "image_area": {"url": "https://pic3.zhimg.com/50/v2-c9d9c229cd252d5ca0b637db8877a930_b.jpg"}, "metrics_area": {"text": "106 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2042012458961695411"}}, "attached_info": "CkkI7MSgrL6ZwaJHEAMaCTExOTY1MjI0MSCsnMzQBjAAODRAFnITMjA0MjAxMjQ1ODk2MTY5NTQxMXgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "23_1779939480.997733", "card_id": "Q_2042963003981526641", "feed_specific": {"answer_count": 109}, "target": {"title_area": {"text": "为什么说喜马拉雅山脉就像一个巨大的空调，中国在室内外机在印度？有科学依据吗？"}, "excerpt_area": {"text": "[视频]"}, "image_area": {"url": "https://pic4.zhimg.com/50/v2-ad01b2cb19f35796070c2444cf92d8c7_b.jpg"}, "metrics_area": {"text": "98 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2042963003981526641"}}, "attached_info": "CkoI7MSgrL6ZwaJHEAMaCTExOTY5MjM1NCDwhtrQBjAAOJgDQBdyEzIwNDI5NjMwMDM5ODE1MjY2NDF4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "24_1779939480.998238", "card_id": "Q_2042639364870627474", "feed_specific": {"answer_count": 39}, "target": {"title_area": {"text": "广州市属国企试点收购二手房，楼龄不限，全面放开商转公组合贷，哪些信息值得关注？"}, "excerpt_area": {"text": "5 月 26 日，广州市举行《关于进一步促进房地产市场平稳健康发展的实施意见》系列配套文件新闻发布会，核心是对 4 月 30 日发布的《关于进一步促进房地产市场平稳健康发展的实施意见》（简称「穗八条」）政策的进一步细化与落实。 《每日经济新闻》记者从会上了解到，多项核心举措细则亮相：国企市场化收购二手住宅划定明确标准、「商转公」全面升级可办组合贷、住房套数与贷款次数限制同步放宽，精准支持刚需与改善型住房需求。 广州安居集团党委副书记、总经理钱喆在发布会上详细介绍国企收购二手住宅试点细则。他表示，安居集团将立即启动「卖旧买新」试点，试行期至 2026 年 12 月 31 日，收购对象标准为：总价 300 万元以内、建筑面积 70 平方米以下、位于广州环城高速以内的二手住宅，楼龄不限，要求房产权属清晰、无抵押查封、无安全隐患。 同时，收购价格以市场成交价为参考，实行「两次评估＋协商确认」机制。由第三方专业机构完成初次询价评估与复核评估，再与居民协商确定最终价格，保障定价公正合理。居民需在二手住宅交易完成后 180 个自然日内，在广州市行政区域内购买新建商品住宅。 而收购后的旧房将优先用于保障性住房、人才公寓等用途，重点服务新市民、青年人等群体的住房需求，以及城市自主更新项目的居民腾迁。 与此同时，住房公积金「商转公」政策迎来系统性优化，也是本次新政核心之一。广州住房公积金管理中心党组书记、主任冯卫透露，这次「商转公」政策的修订是系统性地扩大受益面，降低转贷门槛，这次新政的核心就是「降门槛、扩范围、提额度」。楼市重磅！一地国企下场收购二手房，楼龄不限 | 每经网"}, "image_area": {"url": "https://pic1.zhimg.com/80/v2-d60eb7a562681ebd9bea47d7ad04d330_720w.webp?source=1def8aca"}, "metrics_area": {"text": "96 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2042639364870627474"}}, "attached_info": "CkkI7MSgrL6ZwaJHEAMaCTExOTY3OTIxNyCGrNXQBjAAOG5AGHITMjA0MjYzOTM2NDg3MDYyNzQ3NHgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "25_1779939480.999498", "card_id": "Q_1958488733130126541", "feed_specific": {"answer_count": 19}, "target": {"title_area": {"text": "核电站搞出新副业，竟然是「产珍珠」，核电站为什么会产珍珠？产出的珍珠会不会有辐射？"}, "excerpt_area": {"text": "在海南的昌江黎族自治县境内，有一座核电站，这座核电站除了源源不断地提供电力之外，它还有一个副产品——珍珠。 核电白蝶贝珍珠成品，图：刘玄 核电站为什么会产珍珠？核电站产的珍珠会不会有辐射？今天就来说一说核电站产珍珠这事。 大珠母贝——「澳白」珍珠生产者 准确地说，产珍珠的当然不是核电站了，而是养殖在核电站周围海域里的珍珠贝——大珠母贝，也称白蝶贝。 大珠母贝，图片来源：Wikipedia 你可能没有听说过这种贝的名字，但是它产的珍珠就是珍珠界里的珍品之一——澳白。 之所以叫「澳白」，是因为这种珍珠过去的主要产地在澳洲。当然了，菲律宾、印度尼西亚等地也可以产这类珍珠，所以也有把它们称做「南洋珠」的。 我们国家也有大珠母贝的分布，它们主要集中在比较温暖的海域，比如在广东最南端的雷州半岛、海南、台湾等地。 产自印尼的「南洋珠」，图片来源：Wikipedia 从 20 世纪 60 年代开始，人们为了获取大珠母贝对它们进行了大肆捕捞。目前它们已成为了国家二级保护动物。 这些贝类对水质和环境的要求很高，大规模养殖它们，并且让它们产出高质量的珍珠非常困难，所以「澳白珍珠」才这样珍贵。 可是道理都懂，为什么偏偏是核电站周围能养殖大珠母贝呢？ 核电站搞出新副业，竟然是产珍珠？！"}, "image_area": {"url": "https://pic4.zhimg.com/50/v2-44e0ab77eaf25b5dd54660b85eb65451_b.jpg"}, "metrics_area": {"text": "94 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/1958488733130126541"}}, "attached_info": "CkkI7MSgrL6ZwaJHEAMaCTExNjg0NzI0OSCk5YzHBjAAOFxAGXITMTk1ODQ4ODczMzEzMDEyNjU0MXgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "26_1779939481.837", "card_id": "Q_2042908879680272108", "feed_specific": {"answer_count": 23}, "target": {"title_area": {"text": "谢苗高口碑动作大片《火遮眼》内地正式定档 6 月 11 日上映，早于北美一天，对此你有何期待？"}, "excerpt_area": {"text": "港产动作片《火遮眼》宣布内地定档 6 月 11 日，比北美早上映一天。 谢苗、杨恩又二搭演父女，谢苗以中国功夫对战全球顶级实战高手，功夫、实战柔道、极限武术、班卡苏拉格斗术、全接触空手道五大流派同台开打。 影片由谷垣健治执导，谢苗（《目中无人》系列）、林科灯（《突袭》）、杨恩又（《目中无人 2》、《人生大事》）领衔主演，黎唯（《瞬息全宇宙》）、岩永丞威（《浪客剑心 最终章 人诛篇》）主演，雅彦·鲁伊安（《突袭》系列）特别演出。"}, "image_area": {"url": "https://pic4.zhimg.com/50/v2-fb06026ee82e345f67fa6a3d03ca32f3_b.jpg"}, "metrics_area": {"text": "91 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2042908879680272108"}}, "attached_info": "CkkI7MSgrL6ZwaJHEAMaCTExOTY4ODMyNiCIotnQBjAAOCJAGnITMjA0MjkwODg3OTY4MDI3MjEwOHgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "27_1779939481.1664", "card_id": "Q_2042248304927273782", "feed_specific": {"answer_count": 25}, "target": {"title_area": {"text": "如何看待曾卓君《街霸 6》夺冠斩获 EWC 入场门票后发声「强者不靠馈赠，EWC！你们的王回来了」？"}, "excerpt_area": {"text": "Combo Breaker 2026 街霸 6 总决赛 Xiaohai 击败日本选手 Hinao 夺得冠军，赛后曾卓君更博：强者不靠馈赠，EWC！你们的王回来了！ 此前，EWC 电竞世界杯改规则，街霸卫冕冠军 Xiaohai 失去直通资格，而今日总决赛上 Xiaohai 凭借自己的实力拿到冠军同时也拿下了 EWC 门票。"}, "image_area": {"url": "https://pic3.zhimg.com/50/v2-b9bcb6d8f3fdf8d45e50874264d5fb64_b.jpg"}, "metrics_area": {"text": "90 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2042248304927273782"}}, "attached_info": "CkkI7MSgrL6ZwaJHEAMaCTExOTY2MTgyNiDT08/QBjAAOChAG3ITMjA0MjI0ODMwNDkyNzI3Mzc4MngAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "28_1779939481.2524", "card_id": "Q_1970811077018248483", "feed_specific": {"answer_count": 30}, "target": {"title_area": {"text": "如何看待「功能性训练」越来越受追捧，传统健美技术过时了吗？"}, "excerpt_area": {"text": "观察到一个现象：近几年身边朋友和健身社区里，提到「健身」，不再只是练肌肉块头或单纯追求力量举，越来越多的人开始热衷于 CrossFit 、跑酷、或各类体能训练营，强调「功能性」和「实用性」。而传统的健美训练，似乎在一些人眼中变得有些「老派」。这让我思考，是不是传统的健美或力量训练技术已经不再是主流？这种趋势背后反映了人们对健身目的和身体美学观念的变化吗？想听听大家对这两种训练理念的看法和比较。"}, "image_area": {"url": "https://pic1.zhimg.com/50/v2-441acaaf62750dbbcd85d0a568e8933a_b.jpg"}, "metrics_area": {"text": "84 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/1970811077018248483"}}, "attached_info": "CkkI7MSgrL6ZwaJHEAMaCTExNzI2NDI5OSC4jcDIBjAAOC9AHHITMTk3MDgxMTA3NzAxODI0ODQ4M3gAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "29_1779939481.3191", "card_id": "Q_1931306804442301882"