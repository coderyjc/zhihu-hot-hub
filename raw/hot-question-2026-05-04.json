el_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2033137202750649153"}}, "attached_info": "CkkIw7OMz+vNtpoNEAMaCTExOTMzNTIxNyDziMvPBjAAOG5AG3ITMjAzMzEzNzIwMjc1MDY0OTE1M3gAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "28_1777863257.770297", "card_id": "Q_2032798026104660849", "feed_specific": {"answer_count": 27}, "target": {"title_area": {"text": "吴宣仪被曝与乐华合约到期不续约，却被乐华以「自动续约」条款拒绝，到底怎么回事？法律上站得住脚吗？"}, "excerpt_area": {"text": "3 月底乐华与王一博续约后股价上涨，反观当家花旦吴宣仪，其与乐华的经纪合同于 2026 年 2 月 24 日到期，她已于 2 月 6 日书面通知公司不再续约，却遭乐华拒绝，双方关系僵化甚至可能对簿公堂。吴宣仪在复函中称，乐华主张的 「合同自动续约」 条款系单方格式条款，违背《民法典》，无法律效力，且乐华十年来未向其提供任何演艺、代言合同，报酬也无明确标准。知情人士透露，吴宣仪家人沟通时曾遭乐华怒斥驱赶，且乐华旗下艺人，包括「一哥」王一博均未见过自身演艺合同。"}, "image_area": {"url": "https://picx.zhimg.com/80/v2-b0cafa7f65146dcf5e09fffea7d6c182_1440w.webp?source=1def8aca"}, "metrics_area": {"text": "52 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2032798026104660849"}}, "attached_info": "CkkIw7OMz+vNtpoNEAMaCTExOTMyNDg2NiCQkcbPBjAAOHRAHHITMjAzMjc5ODAyNjEwNDY2MDg0OXgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "29_1777863257.771221", "card_id": "Q_523498716", "feed_specific": {"answer_count": 33}, "target": {"title_area": {"text": "大麦克似乎是一种已经灭绝的香蕉，如果我想吃到能有什么办法吗，还是说再也没有那个可能？"}, "excerpt_area": {"text": "看到好像有别的提问说泰国某些地方好像还有种的，那如果去泰国能吃到吗？"}, "image_area": {"url": "https://pica.zhimg.com/80/v2-9110cc06e10911a3e04c081b88d0e7e5_1440w.webp?source=1def8aca"}, "metrics_area": {"text": "52 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/523498716"}}, "attached_info": "Cj8Iw7OMz+vNtpoNEAMaCDc4NjE0NTMyIMaV55EGMAA4xQFAHXIJNTIzN