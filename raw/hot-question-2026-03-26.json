祺（吴彦祖 饰），在警界掀起一场暗潮涌动的权力较量。英方、警队、富商、黑道四方势力卷入其中互相博弈，香港迎来了新一轮权力洗牌，并为 2017 年的寒战风波埋下了伏笔。 吴彦祖饰蔡元祺 刘俊谦饰李文彬 吴慷仁饰潘志昂 谢君豪饰潘隽亨 王丹妮饰阮若蘭 廖子妤饰潘怡心 周润发饰简奥伟（友情出演） 郭富城饰刘杰辉（友情出演） 梁家辉饰李文彬（友情出演） 古天乐饰叶舜廷（友情出演）"}, "image_area": {"url": "https://pic4.zhimg.com/50/v2-4c2e21b2aa76bcdb7ff6a9ab7385b2a5_b.jpg"}, "metrics_area": {"text": "59 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2018001427360953582"}}, "attached_info": "CkkIranF1uCa6NxFEAMaCTExODgxODk4OCCo6O7NBjAAODdAHXITMjAxODAwMTQyNzM2MDk1MzU4MngAqgEJYmlsbGJvYXJk0gEA"}], "paging": {"is_end": true, "is_start": false, "next": "", "previous": "", "totals": 0}, "fresh_text": "热榜已更新", "display_num": 15, "display_first": true, "fb_bill_main_rise": 0, "head_zone": {"type": "billboard_lantern", "data": [{"id": "2019454020155122269", "link_url": "https://www.zhihu.com/fiore/creator/long-marathon-five", "title": "第五届长篇创作马拉松开始报名", "source_type": 0, "attached_info": "Ci4QABoTMjAxOTQ1NDAyMDE1NTEyMjI2OXITMjAxOTQ1NDAyMDE1NTEyMjI2OXgA", "tag": "活动", "tag_bg_color": "GYL01A"}, {"id": "1989780245977532317", "link_url": "https://www.zhihu.com/appview/community_construction", "title": "辟谣专区", "source_type": 0, "attached_info": "Ci4QABoTMTk4OTc4MDI0NTk3NzUzMjMxN3ITMTk4OTc4MDI0NTk3NzUzMjMxN3gA", "tag": "辟谣", "tag_bg_color": "GRD01A"}]}, "head_zones": [{"type": "billboard_lantern", "data": [{"id": "2019454020155122269", "link_url": "https://www.zhihu.com/fiore/creator/long-marathon-five", "title": "第五届长篇创作马拉松开始报名", "source_type": 0, "attached_info": "Ci4QABoTMjAxOTQ1NDAyMDE1NTEyMjI2OXITMjAxOTQ1NDAyMDE1NTEyMjI2OXgA", "tag": "活动", "tag_bg_color": "GYL01A"}, {"id": "1989780245977532317", "link_url": "https://www.zhihu.com/appview/community_construction", "title": "辟谣专区", "source_type": 0, "attached_info": "Ci4QABoTMTk4OTc4MDI0NTk3NzUzMjMxN3ITMTk4OTc4MDI0NTk3NzUzMjMxN3gA", "tag": "辟谣", "tag_bg_color": "GRD01