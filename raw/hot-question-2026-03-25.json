{"data": [{"type": "hot_list_feed", "style_type": "1", "id": "0_1774414477.238290", "card_id": "Q_2016863431467221790", "card_label": {"type": "boiling", "icon": "https://pic1.zhimg.com/80/v2-a8ec286ae756c2ab8377774b27f8ebc7_1440w.png", "night_icon": "https://pic1.zhimg.com/80/v2-022e7c409e51515f784aa70403aef8d4_1440w.png"}, "feed_specific": {"answer_count": 1104}, "target": {"title_area": {"text": "如何评价周杰伦新专辑《太阳之子》？"}, "excerpt_area": {"text": "   "}, "image_area": {"url": "https://pica.zhimg.com/80/v2-cc95bfa075628adf787af576021501df_1440w.webp?source=1def8aca"}, "metrics_area": {"text": "2031 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2016863431467221790"}}, "attached_info": "CkoIhbvS8dmGgNxpEAMaCTExODc3NTExMCDRoN7NBjAAOK8LQAByEzIwMTY4NjM0MzE0NjcyMjE3OTB4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "1_1774414477.239348", "card_id": "Q_2019452339862331482", "feed_specific": {"answer_count": 215}, "target": {"title_area": {"text": "博主分享东北老妈把欧洲法棍上锅蒸了，法棍变得「入口即化」，为什么欧洲人没想过把法棍蒸一下呢？"}, "excerpt_area": {"text": "刷到一个在欧洲生活的博主，分享自己老妈把硬法棍、香肠上锅蒸了做成「一锅出」。蒸完之后法棍变得很柔软，留子们纷纷表示「还能这样」。 突然很好奇，为什么欧洲人一直是用刀「锯面包」，啃坚硬的面包，从来没想过把面包蒸一下让它柔软一点好入口呢？"}, "image_area": {"url": "https://pica.zhimg.com/v2-ff910ba1ec2b60314ba8818e05843fad.png"}, "metrics_area": {"text": "577 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2019452339862331482"}}, "attached_info": "CkoIhbvS8dmGgNxpEAMaCTExODg2OTAwNSDt9oPOBjAAONUCQAFyEzIwMTk0NTIzMzk4NjIzMzE0ODJ4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "2_1774414477.240143", "card_id": "Q_311937174", "feed_specific": {"answer_count": 282}, "target": {"title_area": {"text": "如果把地球当做一个直径 1cm