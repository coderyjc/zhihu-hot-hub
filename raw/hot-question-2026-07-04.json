hu.com/question/2056342546083570237"}}, "attached_info": "CkkI7qnB5Ka4h7osEAMaCTEyMDI3MzQ2NSCb4JzSBjAAOGRAFXITMjA1NjM0MjU0NjA4MzU3MDIzN3gAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "22_1783171564.829001", "card_id": "Q_2048798434090379217", "card_label": {"type": "new", "icon": "https://pic2.zhimg.com/80/v2-a4b0b52b561281109c51e4957cb20130_1440w.png", "night_icon": "https://pic3.zhimg.com/80/v2-10ef6526c602e55a8c606e46aa0cc586_1440w.png"}, "feed_specific": {"answer_count": 18}, "target": {"title_area": {"text": "梁朝伟被问如何用眼睛演戏，表示自己花很多时间准备，抛开奖项光环，你认为他在华语影坛的演技属于什么级别？"}, "excerpt_area": {"text": "上海国际电影节 上海国际电影节主竞赛单元评委主席： 评委见面会回答如何用眼睛演戏：「我自己准备角色是花很多时间的，我自己那种表演是比较内敛低调的，但是我很注重细节和角色的内心世界，我必须要做很多前期的功课，包括角色的 backstory，他怎么成长，他看什么书，我要把角色的内容弄的很丰富，才能建立信心，才不需要太多动作，让你在眼睛里感受到这个人物。」"}, "image_area": {"url": "https://pica.zhimg.com/50/v2-3f17a8e565c4ad2878d92d0f3fb275f8_b.jpg"}, "metrics_area": {"text": "83 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2048798434090379217"}}, "attached_info": "CkkI7qnB5Ka4h7osEAMaCTExOTk0Njg3NyCb/K7RBjAAOB9AFnITMjA0ODc5ODQzNDA5MDM3OTIxN3gAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "23_1783171564.829434", "card_id": "Q_2055734135813924209", "feed_specific": {"answer_count": 40}, "target": {"title_area": {"text": "如何看待有高考生去招聘软件私聊 HR 咨询志愿择校？这种方式靠谱吗？"}, "excerpt_area": {"text": "[2 张图片]"}, "image_area": {"url": "https://picx.zhimg.com/80/v2-86c206aa51703627a63a4f900359651a_1440w.webp?source=1def8aca"}, "metrics_area": {"text": "78 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2055734135813924209"}}, "attached_info": "CkkI7qnB5Ka4h7osEAMaCTEyMDI0NTMyNiD78pPSBjAAOD9AF3ITMjA1NTczNDEzNTgx