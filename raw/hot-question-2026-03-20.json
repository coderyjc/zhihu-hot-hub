s://picx.zhimg.com/50/v2-22954d3e1c89521c564dfc5302e88a8d_b.jpg"}, "metrics_area": {"text": "88 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2000549449521463712"}}, "attached_info": "CkkI24f28Kaf+OghEAMaCTExODI2NDQxNSC97fDLBjAAOHVADHITMjAwMDU0OTQ0OTUyMTQ2MzcxMngAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "13_1773972472.554814", "card_id": "Q_2017550373682950542", "feed_specific": {"answer_count": 110}, "target": {"title_area": {"text": "如何看待主播「芜湖大司马」直播带货宣称全网最低价，遭弹幕打脸后，厂商瞬间将该商品全网提价的操作？"}, "excerpt_area": {"text": ""}, "image_area": {"url": "https://picx.zhimg.com/80/v2-41dda92cc0980ee758d3bbccb5a7c036_1440w.webp?source=1def8aca"}, "metrics_area": {"text": "87 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2017550373682950542"}}, "attached_info": "CkoI24f28Kaf+OghEAMaCTExODc5OTYwMyCVoOjNBjAAOJQCQA1yEzIwMTc1NTAzNzM2ODI5NTA1NDJ4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "14_1773972472.556151", "card_id": "Q_2018233412289318937", "card_label": {"type": "new", "icon": "https://pic2.zhimg.com/80/v2-a4b0b52b561281109c51e4957cb20130_1440w.png", "night_icon": "https://pic3.zhimg.com/80/v2-10ef6526c602e55a8c606e46aa0cc586_1440w.png"}, "feed_specific": {"answer_count": 75}, "target": {"title_area": {"text": "特朗普会晤高市早苗，把美国袭击伊朗比作日本偷袭珍珠港，如何解读这一言论？如何看待当前美日关系？"}, "excerpt_area": {"text": "特朗普会晤高市早苗 把美国袭击伊朗比作偷袭珍珠港 新华社消息，美国总统特朗普 19 日在白宫会晤到访的日本首相高市早苗，在回答媒体提问时为美国对伊朗发起大规模军事行动辩解，将美国袭击伊朗与日本在第二次世界大战期间偷袭珍珠港相提并论。 特朗普被一名记者问及，为什么没有提前告知日本及其他盟友针对伊朗的战争计划，他说：「我们想要出其不意。还有谁比日本更懂得出其不意呢？你为什么不跟我说说珍珠港？」 特朗普说这番话时，现场一片笑声。坐在一旁的高市早苗睁大了眼睛，在椅子上挪了挪身体，脸上努力保持着微笑。 1941 年 12 月 7 日，日军偷袭夏威夷美国海军基地珍珠港，摧毁、重创多艘美国军舰和上百架飞机，导致美方约 2400 人死亡。次日，美国对日本宣战，太平洋战争爆发。这一事件被时任美国总统罗斯福称为「国耻」，让美国人至今不忘。 2 月 26 日，伊朗与美国第三轮间接谈判在瑞士日内瓦举行，未达成协议，但各方作出积极评价，并宣布计划 3 月 2 日在奥地利首都维也纳继续进行技术讨论。然而，同月 28 日，以色列和美国突然对伊朗发动大规模空袭，造成时任伊朗最高领袖哈梅内伊和多名军政高级官员丧生。伊朗随后用弹道导弹和无人机对以色列以及美国在中东地区的军事基地等目标发起还击。特朗普会晤高市早苗 把美国袭击伊朗比作偷袭珍珠港 - 新华网"}, "image_area": {"url": "https://picx.zhimg.com/80/v2-103ca14d08ed4d6c8482f392282cff1a_720w.webp?source=1def8aca"}, "metrics_area": {"text": "87 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2018233412289318937"}}, "attached_info": "CkkI24f28Kaf+OghEAMaCTExODgyNTU1MyC2mPLNBjAAOGdADnITMjAxODIzMzQxMjI4OTMxODkzN3gAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "15_1773972472.559406", "card_id": "Q_2018016098444863053", "feed_specific": {"answer_count": 385}, "target": {"title_area": {"text": "新一代小米 SU7 发布，全系搭载 V6s Plus 超级电机，最高续航达 902km，还有哪些看点？"}, "excerpt_area": {"text": "3 月 19 日晚间消息，2026 新一代 SU7 春季新品发布会举行。 发布会上，新一代小米 SU7 性能数据公布：全系搭载 V6s Plus 超级电机，Max 版零百加速 3.08s，最高时速 265km/h；Pro 版 CLTC 续航 902km，Max 版 CLTC 续航 835km，标准版 CLTC 续航 720km ；全系碳化硅高压平台，Max 版最大充电倍率 5.2C，10%-80% 最快充电时间 12 分钟。 新一代小米 SU7 发布：全系搭载 V6s Plus 超级电机，Pro 版 CLTC 续航 902km 持续三个月的信息释放，正式上市，还有哪些惊喜？这些升级对于两年这个周期来说合格吗？"}, "image_area": {"url": "https://picx.zhimg.com/v2-48f485c67b122766ee57db3ec98a79db_1440w.png"}, "metrics_area": {"text": "87 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2018016098444863053"}}, "attached_info": "CkoI24f28Kaf+OghEAMaCTExODgxOTc0MSDSg+/NBjAAOLEGQA9yEzIwMTgwMTYwOTg0NDQ4NjMwNTN4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "16_1773972472.561286", "card_id": "Q_2018114384203924458", "card_label": {"type": "new", "icon": "https://pic2.zhimg.com/80/v2-a4b0b52b561281109c51e4957cb