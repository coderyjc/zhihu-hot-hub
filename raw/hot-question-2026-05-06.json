lor": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2035305743931458002"}}, "attached_info": "CkkI8qK9oLq0rft7EAMaCTExOTM5ODc1MCCP0OrPBjAAOBpADnITMjAzNTMwNTc0MzkzMTQ1ODAwMngAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "15_1778076744.385885", "card_id": "Q_2035308080544441250", "feed_specific": {"answer_count": 23}, "target": {"title_area": {"text": "如何看待天弘余额宝 7 日年化收益率跌破 1%，创历史新低？"}, "excerpt_area": {"text": "昔日被誉为「国民理财神器」的余额宝，如今收益率正式进入「0 时代」。5 月 2 日，天弘余额宝货币市场基金近 7 日年化收益率降至 0.999%，历史上首次跌破 1% 的整数关口。 资料显示，天弘余额宝曾在 2014 年初创下超过 6.7% 的七日年化收益率峰值，此后历经多轮下行周期，其间虽有短暂回升，但整体趋势持续走低。2020 年 4 月，该收益率首度跌破 2%；2022 年 11 月又失守 1.5%；如今再度下探，迈入「0 时代」。余额宝，首次破「1」"}, "image_area": {"url": "https://pic4.zhimg.com/50/v2-41fa2f7cf3442fd8ebbe740495782b4b_b.jpg"}, "metrics_area": {"text": "134 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2035308080544441250"}}, "attached_info": "CkkI8qK9oLq0rft7EAMaCTExOTM5ODkzNiC81OrPBjAAOFdAD3ITMjAzNTMwODA4MDU0NDQ0MTI1MHgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "16_1778076744.386438", "card_id": "Q_2034453660378382744", "feed_specific": {"answer_count": 81}, "target": {"title_area": {"text": "为什么美股在大涨特涨，巴菲特等金融专家却在持续减持？"}, "excerpt_area": {"text": ""}, "image_area": {"url": "https://picx.zhimg.com/v2-31d527fab0ee6b70a47d885ce5ad4d0f_l.jpg?source=57bbeac9"}, "metrics_area": {"text": "109 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2034453660378382744"}}, "attached_info": "CkoI8qK9oLq0rft7EAMaCTExOTM3NTY4OCD+nN7PBjAAOKsBQBByEzIwMzQ0NTM2NjAzNzgzODI3NDR4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "17_1778076744.386730"