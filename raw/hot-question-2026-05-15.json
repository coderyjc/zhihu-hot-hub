{"data": [{"type": "hot_list_feed", "style_type": "1", "id": "0_1778834963.212630", "card_id": "Q_2038010908488590805", "card_label": {"type": "boiling", "icon": "https://pic1.zhimg.com/80/v2-a8ec286ae756c2ab8377774b27f8ebc7_1440w.png", "night_icon": "https://pic1.zhimg.com/80/v2-022e7c409e51515f784aa70403aef8d4_1440w.png"}, "feed_specific": {"answer_count": 497}, "target": {"title_area": {"text": "国际社会是怎样看待特朗普本次访华行程的？"}, "excerpt_area": {"text": ""}, "image_area": {"url": "https://picx.zhimg.com/v2-0f95b15bd3a0251e23687340e328f520.png"}, "metrics_area": {"text": "2878 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2038010908488590805"}}, "attached_info": "CkoIpvXkj/bc3qZnEAMaCTExOTQ5NjI0OSDx/pHQBjAAOK0NQAByEzIwMzgwMTA5MDg0ODg1OTA4MDV4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "1_1778834963.213407", "card_id": "Q_2038367718697431356", "feed_specific": {"answer_count": 268}, "target": {"title_area": {"text": "媒体报道称俄罗斯总统普京即将访华，有哪些信息值得关注？"}, "excerpt_area": {"text": "据环球网，克里姆林宫发言人佩斯科夫 14 日在新闻发布会上表示，俄罗斯总统普京即将访华，相关筹备工作已就绪。 据报道，当被问及普京访华日期是否已经明确时，佩斯科夫回应称，「我们将于近期公布具体日期。此次访问正在筹备中。可以说，各项准备工作，包括最后的收尾工作，都已经完成。访问很快就会进行。」 克宫宣布：普京即将访华"}, "image_area": {"url": "https://picx.zhimg.com/v2-84f7c1c34ad65dc6a2592b993eb0bfa0.png"}, "metrics_area": {"text": "1673 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2038367718697431356"}}, "attached_info": "CkoIpvXkj/bc3qZnEAMaCTExOTUwOTA0OCC/l5fQBjAAOKgGQAFyEzIwMzgzNjc3MTg2OTc0MzEzNTZ4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "2_1778834963.214188", "card_id": "Q_2038626152567281104", "card_label": {"type": "new", "icon": "https://pic2.zhimg.com/80/v2-a4b0b52b56128110