_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2019504335671832718"}}, "attached_info": "CkkI3YvLme/J5YdOEAMaCTExODg3MTEyOSDa14TOBjAAOB1AGnITMjAxOTUwNDMzNTY3MTgzMjcxOHgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "27_1778844107.222529", "card_id": "Q_7349267991", "feed_specific": {"answer_count": 22}, "target": {"title_area": {"text": "现在的小女孩为什么很少有戴发箍的了，原因是什么？"}, "excerpt_area": {"text": "我印象中，我是 00 年的，我那上小学，初中那时候，无论是身边的女同学还是同年龄段的女孩，那时候貌似都很喜欢扎马尾，头上戴发箍，看着也是很漂亮，而且五花八门的都有，尤其是很多喜欢带白色的，黑色的，粉色的，各种各样的都有。而且很多小女孩那个时候基本上都是天天戴发箍。 不过貌似在我 2015 年上了高中之后，生活当中就看到小学生初中生的小女孩很少有戴发箍的了，而且还是一年比一年少，到了快 2025 年了，我看现在的小女孩基本上没有戴发箍的了，反正在我这里是这样的，不知道别的地方怎么样... 而且发箍感觉以前只有小学生和初中生喜欢戴，到了上高中年龄大了基本上看不到了 所以说，现在上学的小女孩为什么很少有戴发箍的了？原因是什么呀？还有女孩年龄大了，为什么就不喜欢戴发箍了？原因是什么呀？"}, "image_area": {"url": ""}, "metrics_area": {"text": "65 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/7349267991"}}, "attached_info": "CkAI3YvLme/J5YdOEAMaCTExMjQ0NjU1MiDzjpO7BjAAOB1AG3IKNzM0OTI2Nzk5MXgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "28_1778844107.223035", "card_id": "Q_2038417622446896966", "feed_specific": {"answer_count": 39}, "target": {"title_area": {"text": "如何评价《一人之下》漫画第 762（814）话？"}, "excerpt_area": {"text": "「苦主」"}, "image_area": {"url": "https://pic4.zhimg.com/50/v2-a28874a071b66de8d758ce53aa766a59_b.jpg"}, "metrics_area": {"text": "65 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2038417622446896966"}}, "attached_info": "CkkI3YvLme/J5YdOEAMaCTExOTUxMTAyNyC59JfQBjAAOC9AHHITMjAzODQxNzYyMjQ0Njg5Njk2NngAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "29_1778844107.223337", "card_id": "Q_1949416418996101662", "card_label": {"type": "new", "icon": "https://pic2.zhimg.com/80/v2-a4b0b52b561281109c51e4957cb20130_1440w.png", "night_icon": "https://pic3.zhimg.com/80/v2-10ef6526c602e55a8c606e46aa0cc586_1440w.png"}, "feed_specific": {"answer_count": 23}, "target": {"title_area": {"text": "哪些考古发现彻底颠覆了我们对中国古代史的认知？"}, "excerpt_area": {"text": "传统历史教科书的内容，往往是基于已有的文献记载和考古证据构建的。然而，近年来，一些重大的考古新发现，例如三星堆遗址、海昏侯墓等，不断出土了大量前所未见的文物和遗迹。这些发现不仅填补了历史空白，有些甚至与传统史料记载存在显著差异，引发了学术界对某些历史事件、文化交流轨迹乃至文明起源的新一轮思考。一位资深历史爱好者，在参观最新考古成果展时，对这些发现冲击原有历史框架的强大力量感到震撼。想请教各位专业人士，目前有哪些考古发现，是真正意义上动摇或颠覆了我们对中国古代历史的根本看法？它们是如何带来这种改变的？"}, "image_area": {"url": "https://pic1.zhimg.com/50/v2-91eb94975c11aab1313c8f3ae4fd780e_b.jpg"}, "metrics_area": {"text": "64 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/1949416418996101662"}}, "attached_info": "CkoI3YvLme/J5YdOEAMaCTExNjU0Njc4NCDk4ojGBjAAONACQB1yEzE5NDk0MTY0MTg5OTYxMDE2NjJ4AKoBCWJpbGxib2FyZNIBAA=="}], "paging": {"is_end": true, "is_start": false, "next": "", "previous": "", "totals": 0}, "fresh_text": "热榜已更新", "display_num": 15, "display_first": true, "fb_bill_main_rise": 0, "head_zone": {"type": "billboard_lantern", "data": [{"id": "1989780245977532317", "link_url": "https://www.zhihu.com/appview/community_construction", "title": "辟谣专区", "source_type": 0, "attached_info": "Ci4QABoTMTk4OTc4MDI0NTk3NzUzMjMxN3ITMTk4OTc4MDI0NTk3NzUzMjMxN3gA", "tag": "辟谣", "tag_bg_color": "GRD01A"}]}, "head_zones": [{"type": "billboard_lantern", "data": [{"id": "1989780245977532317", "link_url": "https://www.zhihu.com/appview/community_construction", "title": "辟谣专区", "source_type": 0, "attached_info": "Ci4QABoTMTk4OTc4MDI0NTk3NzUzMjMxN3ITMTk4OTc4MDI0NTk3NzUzMjMxN3gA", "tag": "辟谣", "tag_bg_color": "GRD01A"}]}]}