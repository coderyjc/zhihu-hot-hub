跌更多，跌幅为 4.5%，而西部跌幅为 3.2%。出生人口唯一正增长的州是汉堡州。 德国联邦统计局说，最近几年德国出生人口连年下跌，部分原因是正值生育年龄的 90 后人口较少。据德新社报道，1989 年柏林墙倒下，随后德国统一，在上世纪 90 年代德国出生的人口减少。 德新社援引的初步统计显示，2025 年出生人口减少的欧洲国家还包括法国、奥地利、意大利和瑞典。（王宏彬）德国 2025 年出生人口创二战后新低 - 新华网"}, "image_area": {"url": "https://picx.zhimg.com/v2-426974ab35587d6369eeaa8cb91ec2bd.png"}, "metrics_area": {"text": "69 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2033901199972419423"}}, "attached_info": "CkoIpbmqusmO/8BZEAMaCTExOTM2MDU0NiD6l9bPBjAAOJsBQB1yEzIwMzM5MDExOTk5NzI0MTk0MjN4AKoBCWJpbGxib2FyZNIBAA=="}], "paging": {"is_end": true, "is_start": false, "next": "", "previous": "", "totals": 0}, "fresh_text": "热榜已更新", "display_num": 15, "display_first": true, "fb_bill_main_rise": 0, "head_zone": {"type": "billboard_lantern", "data": [{"id": "1989780245977532317", "link_url": "https://www.zhihu.com/appview/community_construction", "title": "辟谣专区", "source_type": 0, "attached_info": "Ci4QABoTMTk4OTc4MDI0NTk3NzUzMjMxN3ITMTk4OTc4MDI0NTk3NzUzMjMxN3gA", "tag": "辟谣", "tag_bg_color": "GRD01A"}]}, "head_zones": [{"type": "billboard_lantern", "data": [{"id": "1989780245977532317", "link_url": "https://www.zhihu.com/appview/community_construction", "title": "辟谣专区", "source_type": 0, "attached_info": "Ci4QABoTMTk4OTc4MDI0NTk3NzUzMjMxN3ITMTk4OTc4MDI0NTk3NzUzMjMxN3gA", "tag": "辟谣", "tag_bg_color": "GRD01A"}]}]}