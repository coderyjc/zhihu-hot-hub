=1def8aca"}, "metrics_area": {"text": "367 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2043273255205832365"}}, "attached_info": "CkoIqreU//GqkPV3EAMaCTExOTcwMzg0MyDiyN7QBjAAOIwBQANyEzIwNDMyNzMyNTUyMDU4MzIzNjV4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "4_1781359202.926100", "card_id": "Q_2048499018230149377", "card_label": {"type": "hot", "icon": "https://pic2.zhimg.com/80/v2-266e83dbee46dce23b718e0531cb7d3a_1440w.png", "night_icon": "https://pic3.zhimg.com/80/v2-c89199839c237b87e52f010bb5e7d773_1440w.png"}, "feed_specific": {"answer_count": 29}, "target": {"title_area": {"text": "路虎揽胜极光 L 售价跌破 18 万，曾落地近 90 万，这说明了什么？"}, "excerpt_area": {"text": "路虎揽胜极光 l 售价跌破 18 万，曾经落地近 90 万还一车难求"}, "image_area": {"url": "https://pic1.zhimg.com/50/v2-fe332899e2f637a82441a8f32c0ec6fa_b.jpg"}, "metrics_area": {"text": "237 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2048499018230149377"}}, "attached_info": "CkkIqreU//GqkPV3EAMaCTExOTkzMzY1NyDBzqrRBjAAODdABHITMjA0ODQ5OTAxODIzMDE0OTM3N3gAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "5_1781359202.926575", "card_id": "Q_2047372994247496254", "feed_specific": {"answer_count": 31}, "target": {"title_area": {"text": "吕秀才穷酸还自负，为啥郭芙蓉一个千金小姐能看上他？"}, "excerpt_area": {"text": "《武林外传》中，吕秀才是个数次考科举，次次落榜的酸秀才，死读书却只能靠着变卖家产过日子，要不是佟湘玉买了他的店，帮他还了债，还给了他一个账房的工作，吕秀才说不定还得把唯一的地契也当了换钱。 而郭芙蓉是江湖有名大侠的千金，众多有钱公子可以选择，她怎么会喜欢吕秀才这样的人呢？"}, "image_area": {"url": "https://picx.zhimg.com/80/v2-5795276739ba8287e14216978dba00f8_1440w.webp?source=1def8aca"}, "metrics_area": {"text": "216 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": 