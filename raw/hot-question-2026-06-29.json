49955f03de_b.jpg"}, "metrics_area": {"text": "66 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/1921003384158294430"}}, "attached_info": "CkkImpj3idKqoqN3EAMaCTExNTUzODQyNCCxp+vCBjAAOClAGnITMTkyMTAwMzM4NDE1ODI5NDQzMHgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "27_1782730799.554353", "card_id": "Q_2047738930548695875", "card_label": {"type": "new", "icon": "https://pic2.zhimg.com/80/v2-a4b0b52b561281109c51e4957cb20130_1440w.png", "night_icon": "https://pic3.zhimg.com/80/v2-10ef6526c602e55a8c606e46aa0cc586_1440w.png"}, "feed_specific": {"answer_count": 25}, "target": {"title_area": {"text": "哪部作品、哪本书、哪首歌，值得被一直传下去？"}, "excerpt_area": {"text": ""}, "image_area": {"url": "https://pic2.zhimg.com/50/v2-d7d6c6adbda358657ca3bb4f0c0403ab_b.jpg"}, "metrics_area": {"text": "61 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2047738930548695875"}}, "attached_info": "CkkImpj3idKqoqN3EAMaCTExOTkwMDExMCDexp/RBjAAODtAG3ITMjA0NzczODkzMDU0ODY5NTg3NXgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "28_1782730799.554544", "card_id": "Q_2050995360852717840", "feed_specific": {"answer_count": 22}, "target": {"title_area": {"text": "如何评价林离 Olivia 桌面软件《BSide: Olivia Lin》登录 Steam 抢先体验？"}, "excerpt_area": {"text": "商店页面：（仅限国区） 需要登录米哈游通行证。 林离，一个主修钢琴、辅修心理学的上海女生。她钟爱黑胶、老电影和雨天，正在进行一项关于「音乐与回忆」的个人研究。在这里，你可以沉浸感受她的演奏，也可以上传你的音乐文件、和她分享你的创作与灵感。或者，给她写一封信——用文字表达此刻的情绪，和她交换一段只属于你们的故事。她在等你。更多的她，和她聊聊就知道了。为何要采用抢先体验这种模式？ 「BSide: Olivia Lin 目前还在持续打磨与迭代中，我们并不打算等到所有功能都完美无缺时再呈现给大家。作为一款融合了音乐播放、 MIDI 上传生成视频以及写信等功能的产品，我们非常需要了解用户在真实使用场景下的感受——尤其是对视频生成质量、播放体验和写信交互的反馈，这些都将帮助我们更精准、更高效地优化整个产品。所以我们真诚地希望听到来自社群的声音，并会在后续开发过程中认真听取每一条建议。」这款软件的抢先体验状态大约持续多久？ 「我们预计抢先体验阶段将持续至 2026 年底。在此期间，我们希望尽可能多地收集用户对 BSide: Olivia Lin 的意见与建议，将产品打磨到足够成熟、足够好用的状态再正式推出 1.0 版本。具体时间仍可能根据开发进展调整。」计划中的完整版本和抢先体验版本到底有多少不同？ 「在抢先体验阶段，我们会优先优化产品的核心体验，包括音乐播放的流畅度与音质表现、 MIDI 上传到视频生成的准确性与速度、写信功能的交互体验等。在完整版本中，我们计划探索更丰富的功能方向，可能包括更多音色与风格选择、更智能的 MIDI 编辑与处理、信件的多样化模板等。」抢先体验版本的现状如何？ 「当前的抢先体验版本已经包含 BSide: Olivia Lin 的主要基础功能。 用户可以进行音乐视频播放，体验基础的音乐聆听功能；也可以上传 MIDI 文件并生成视频，用于音乐创作、试听或灵感记录。同时，写信功能也已经开放，用户可以通过文字表达情绪、记录想法，或与林离 Olivia 建立更具沉浸感的互动。 需要说明的是，当前版本仍然处于持续优化阶段，部分功能在体验、性能、生成效果和细节表现上还会继续改进。我们希望通过抢先体验收集更多真实反馈，帮助我们判断哪些功能最需要优化，哪些方向最值得继续扩展。」在抢先体验期间和结束之后，这款软件的价格会有所不同吗？ 「BSide: Olivia Lin 目前计划以免费形式提供给用户体验。抢先体验期间，用户可以免费使用当前开放的功能；在抢先体验结束后，我们也计划继续保持基础体验免费。」在开发过程中，你们是如何计划让玩家社区参与进来的？ 「我们相信，与抢先体验用户保持定期、坦诚的交流，是 BSide: Olivia Lin 走向成功的关键。我们的团队会通过多种渠道与用户沟通，主动征集反馈，让大家真正参与到产品的成长中来。我们会及时同步当前的开发方向，也非常期待听到大家关于新功能、新内容的建议，告诉我们大家希望在 BSide: Olivia Lin 中看到什么。欢迎大家通过各类社区渠道关注我们并积极参与！」"}, "image_area": {"url": "https://pica.zhimg.com/50/v2-e9a7219dc662716b1c4d4e2836606490_b.jpg"}, "metrics_area": {"text": "58 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2050995360852717840"}}, "attached_info": "CkkImpj3idKqoqN3EAMaCTEyMDAzOTAyNyCn+M7RBjAAOCVAHHITMjA1MDk5NTM2MDg1MjcxNzg0MHgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "29_1782730799.556123", "card_id": "Q_2053864133800485762", "feed_specific": {"answer_count": 60}, "target": {"title_area": {"text": "想买一台既能接待客户又能全家出游的全尺寸 SUV，哪些配置是必不可少的？"}, "excerpt_area": {"text": "最近在看全尺寸 SUV，用车场景是「既要又要」：平时开车接待客户，要体面高效；周末又要带父母、老婆孩子出游，空间、舒适性和安全感也不能妥协。这个级别的车价格不低，所以不想只单纯看配置表，还希望各方面能力都比较均衡。大家觉得一台能兼顾商务接待和家庭出行的全尺寸 SUV，哪些配置才是真正必不可少的？"}, "image_area": {"url": "https://pic2.zhimg.com/50/v2-fc3807098d903608317eb8d423808b7b_b.jpg"}, "metrics_area": {"text": "57 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_col