_1440w.webp?source=1def8aca"}, "metrics_area": {"text": "102 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2009245585287439261"}}, "attached_info": "CkkIuPKh5JnQo4ZgEAMaCTExODUxNDY2OSCls+/MBjAAOEFADnITMjAwOTI0NTU4NTI4NzQzOTI2MXgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "15_1778926588.980880", "card_id": "Q_2038563006892568719", "card_label": {"type": "new", "icon": "https://pic2.zhimg.com/80/v2-a4b0b52b561281109c51e4957cb20130_1440w.png", "night_icon": "https://pic3.zhimg.com/80/v2-10ef6526c602e55a8c606e46aa0cc586_1440w.png"}, "feed_specific": {"answer_count": 17}, "target": {"title_area": {"text": "英伟达市值破 5.5 万亿美元，超世界第三大经济体德国 GDP，如何看待 AI 的财富效应？"}, "excerpt_area": {"text": "5 月 14 日，英伟达（NVIDIA）公司市值盘中首次突破 5.5 万亿美元，刷新全球上市公司市值历史最高纪录，也是全球首家站上这一关口的上市公司。 英伟达在当天早盘后股价上涨 3%，从 2026 年年初至今，公司市值已增长 19.58%，进一步巩固其全球市值最高公司的位置。 从横向对比看，英伟达已明显甩开主要科技巨头，谷歌母公司 Alphabet 市值为 4.86 万亿美元；苹果公司市值为 4.39 万亿美元，微软公司市值为 3.01 万亿美元。（来源：IT 之家）史上首家！英伟达市值破 5.5 万亿美元，超世界第三大经济体德国 GDP"}, "image_area": {"url": "https://pic4.zhimg.com/50/v2-0fa25c972a0e4a5c4534dccf9544fb9f_b.jpg"}, "metrics_area": {"text": "99 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2038563006892568719"}}, "attached_info": "CkkIuPKh5JnQo4ZgEAMaCTExOTUxMzg0NCCfg5rQBjAAOBtAD3ITMjAzODU2MzAwNjg5MjU2ODcxOXgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "16_1778926588.983236", "card_id": "Q_2036084258695901324", "feed_specific": {"answer_count": 42}, "target": {"title_area": {"text": "律师声称原创内容被央视网抄袭，连刻意埋下的瑕疵表达一并抄走，算侵权吗？作者沟通无果，是不是只能忍了？"}, "excerpt_area": {"text": "一、不敢相信自己的眼睛 1. 刚代理完一起 AI 侵权案，我接受媒体新榜采访，就 AI 配音话题发表了法律评论意见，刊在新榜公众号文章《被 AI「偷走」声音？一线配音演员集体向 AI 侵权宣战？》里。没过多久，我看到央视网也做了一期同样选题的报道《配音…AI，…版权…？》。我第一反应还挺高兴的，认为自己还挺有新闻触觉。 2. 但越读越不对劲，直到我把央视网的文章逐字扒完，得出了一个让我难以置信的结论：我的原创内容被抄袭了。不多说，把比对结果放出来： （央视网文章（左）、我的原创内容（右）） （更直观的「调色盘」抄袭比对） 3. 或许有人会反驳：「大家都在聊同一个话题，观点难免雷同，凭什么说人家央视抄你？」 4. 一开始我也不大敢相信堂堂央视会干这种事，毕竟一个国家级权威媒体。我还特意去问了新榜的编辑老师，得到的答复是：新榜也没有授权央视网使用我的原创内容。而且我通常与媒体的合作形式都是独家采访，也不可能同意合作媒体随意授权他人，如此改头换面地使用我的内容啊。 （新榜老师回复确认未授权） 二、我的原创，自带防伪 虽然被改头换面，但其实我的原创内容里，都有大量「防伪标签」，只要遭遇别人抄袭，就会像考试被同桌抄袭那样，把我试卷上的错题、甚至连名带姓一并抄了过去。随便举几个例子： 1. 中文语病表达：「已大量开源」——属于非常规表达，常见说法应为「已大量处于开源阶段」，我当初写的时候，还特意去全网搜了一下，确定没有前人使用过「已大量开源」这样的表述，才刻意使用这种「带病表达」的，没关系，读者能看懂就行。 不管他们怎么删，他们绝对没有想到，还有其他这么多「雷同之处」。更没想到我这种「故意埋雷」的写作技巧——其实我在 2019 年 7 月 5 日写过一篇文章我被抄袭了，对方是央视 央视报道被 AI「偷走」声音？一线配音演员集体向 AI 侵权宣战"}, "image_area": {"url": "https://picx.zhimg.com/v2-0444906ce74063675f9f9c711c2cd0eb_1440w.jpg"}, "metrics_area": {"text": "87 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2036084258695901324"}}, "attached_info": "CkoIuPKh5JnQo4ZgEAMaCTExOTQyNjc2NCCb+vXPBjAAOIIBQBByEzIwMzYwODQyNTg2OTU5MDEzMjR4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "17_1778926588.985490", "card_id": "Q_2037684043257472040", "feed_specific": {"answer_count": 42}, "target": {"title_area": {"text": "全球昆虫正在以惊人速度灭绝，这会对地球生态系统带来哪些连锁影响？"}, "excerpt_area": {"text": "全球昆虫正在以惊人速度灭绝"}, "image_area": {"url": "https://picx.zhimg.com/80/v2-16b95761d51f240d9b7ac1468eff8e5c_1440w.webp?source=1def8aca"}, "metrics_area": {"text": "74 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2037684043257472040"}}, "attached_info": "CkkIuPKh5JnQo4ZgEAMaCTExOTQ4NDMyOSCGno3QBjAAOHJAEXITMjAzNzY4NDA0MzI1NzQ3MjA0MHgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "18_1778926588.986051", "card_id": "Q_376157575", "feed_specific": {"answer_count": 214}, "target": {"title_area": {"text": "有没有很冷门但很神仙的网站？"}, "excerpt_area": {"text": "类似于『彩虹屁生成器’』AI 人脸合成’这种很好玩又很神仙的网站。"}, "image_area": {"url": "https://pic2.zhimg.com/50/v2-4fd10dfc25b418349de543eb8eb4dcef_b.jpg"}, "metrics_area": {"text": "59 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/376157575"}}, "attached_info": "Cj8IuPKh5JnQo4ZgEAMaCDQ1ODY4NjM4IJOI8/IFMAA4ohlAEnIJMzc2MTU3NTc1eACqAQliaWxsYm9hcmTSAQA="}, {"type": "hot_list_feed", "style_type": "1", "id": "19_1778926588.986397", "card_id": "Q_2034535627887263843", "feed_specific": {"answer_count": 39}, "target": {"title_area": {"text": "在美剧《黑袍纠察队》中，祖国人最大的痛苦是什么呢？"}, "excerpt_area": {"text": "[图片]"}, "image_area": {"url": "https://pic1.zhimg.com/50/v2-913aaecdc6edd74cbb8e3237e44dc722_b.jpg"}, "metrics_area": {"text": "58 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2034535627887263843"}}, "attached_info": "CkkIuPKh5JnQo4ZgEAMaCTExOTM3NjQ5MyDVtd/PBjAAOFJAE3ITMjAzNDUzNTYyNzg4NzI2Mzg0M3gAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "20_1778926588.986753", "card_id": "Q_1975280202390205761", "feed_specific": {"answer_count": 282}, "target": {"title_area": {"text": "曾经在一起四年的前男朋友结婚已经两年了，但我还是走不出来，怎么办？"}, "excerpt_area": {"text": "我和前男友相识于大二，我们在临汾上学，那个时候他刚退伍也读大二，他和他父母完全把我当做了他们家的人，在一起的前几年我觉得我是世界上最幸福的人，后来 22 年我考上了研究生在西安，他没有考上，我们就异地了。之后他参加了选调和村官考试也都没考上，陆陆续续的给人带军训，不太稳定，我督促他学习，后来他考上了临汾市小县城的小学体育老师编制，我跟他闹了点矛盾，他也不给我打电话，我俩冷战了半个月，他跟我提了分手，理由是家离得远，吃不到一起，性格不合。我当时很难受给他好朋友发消息，说我买不到票只能座晚上的硬座凌晨四点到，我想去找他（他当时在他朋友旁边）。后来我一个人很难受，不想让自己这么卑微，我把票退了。晚上十一点多他给我发消息问我为什么不说话，我回了他，然后他说他喝醉了，明天再说。然后就没说话了，他把我微信抖音 qq 都屏蔽了。两个月来我忙着做实验，每天也提不起兴趣，我总感觉他还会回来找我，因为他说过很想娶我，我想等他低头。后来有一天我看到他送我的挂件就很难受，点开了他的抖音，我看到主页背景是他和一个女孩牵手的照片。我去跟他的朋友证实了这件事。从他朋友那里我得知他们准备要订婚了，我如晴天霹雳，一切都来不及了。我不知道该怎么办，我想去见他一面，但是我也很犹豫，没做好准备，后来我写了一些话给他，但一直没发给他。突然有一天他把朋友圈的权限对我打开了，从他朋友那里得知他第二天就要订婚了（23 年底）。我知道我们可能再也见不到了，我把我写的话发给他，听他朋友说他哭的很厉害，他的新女朋友都招架不住。后来，我们就没有联系了，第二年他结婚了 (24 年)，25 年他有了小孩。 其实从我们在一起他就一直把想娶我挂在嘴边，可能也是他周围同龄人都结婚的缘故，对于我来说，我周围基本也没有结婚的人，所以我也没觉得这是一件急迫的事情。他还会把朋友家的小孩抱在怀里一个劲的给我看。现在他想要的一切都有了，他应该很辛福吧，他家里还有一只金毛，有一次我俩同时朝两个方向跑，小狗跟我走了，所以我也很舍不得那小狗。我们在一起四年，从 23 年九月分手到现在我还是没有走出来，后来陆陆续续也遇到一些人，但是相处之后感觉更多的是现实问题，感情里要考虑太多的事情，很不纯粹。我还是觉得只有他是把我当做一家人来对待。 我好恨，我也超级嫉妒，为什么是这样。我们 4 年的感情，他和我分手不到两个月就准备订婚了。他当时发结婚照时文案是她追的我，我真的好讨厌那个女生。23 年过年的时候，他发了一条朋友圈，写的是所得皆所愿，我真的好难受。不知道为什么，我还是走不出来。当别人对我不好的时候，我还是会止不住的想他，我该怎么办？异地的那个阶段可能会有一些分歧，但是为什么没有坚持下来？ 以前的我确实有一些心高气傲，我不想在小地方发展，我也跟他提过，但是我现在一个人在西安，工作也不顺心，生活的也不开心，我感觉有好多的挫折，为什么我当初没有选择去求他跟他在一起，然后在小县城过着平淡的生活，为什么跟他牵着手生活在一起，每天去遛狗的人不是我。我想过要坚强，但我感觉这都是在麻痹我自己，难受的时候晚上都能梦到他。以前的多么宏伟的期待，我发现我完全没有这个能力去做到这件事情，我总以为我现在身上有的那些荣誉和身份能够给我带来更好的发展，但是并没有，现如今我看清了自己，但是我已经没有机会了。可是我真的好遗憾啊！我真的太难受了，有没有哪个好人能够开导开导我。"}, "image_area": {"url": "https://pica.zhimg.com/80/v2-33f5410006e56f025ee943e7a5198073_1440w.webp?source=1def8aca"}, "metrics_area": {"text": "58 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/1975280202390205761"}}, "attached_info": "CkoIuPKh5JnQo4ZgEAMaCTExNzQyMTIzOCDrkYHJBjAAOP4DQBRyEzE5NzUyODAyMDIzOTAyMDU3NjF4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "21_1778926588.990399", "card_id": "Q_2038261956851802377", "feed_specific": {"answer_count": 161}, "target": {"title_area": {"text": "90 后男子在医学院读硕博期间套取 1426 万元科研经费，如何看待此事？高校科研经费管理存在哪些漏洞？"}, "excerpt_area": {"text": "在某医学院攻读硕士研究生、博士研究生期间，「90 后」男子柴某竟套取科研经费 1426 万余元。5 月 15 日，红星新闻记者从中国裁判文书网获悉，福建福州市中院近日公开该案二审裁定书，驳回柴某上诉，维持原判。此前一审中，柴某因犯诈骗罪，被判处有期徒刑 8 年。 33 岁的柴某系江苏人，案发前系某医院博士后研究人员。一审法院认定，2018 年至 2023 年，柴某在某医科大学某临床医学院（以下简称某医学院）攻读外科学硕士研究生、外科学博士研究生。作为导师科研团队队员，柴某参与导师团队相关科研工作，并作为经办人员协助导师团队办理科研经费报销等业务。 90 后男子在医学院读硕博期间套取 1426 万科研经费，犯诈骗罪被判 8 年"}, "image_area": {"url": "https://pic1.zhimg.com/v2-f94b3093434c09b4501b056d142025e0_qhd.jpg?source=57bbeac9"}, "metrics_area": {"text": "58 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2038261956851802377"}}, "attached_info": "CkoIuPKh5JnQo4ZgEAMaCTExOTUwNDU1MCC/0pXQBjAAOL4DQBVyEzIwMzgyNjE5NTY4NTE4MDIzNzd4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "22_1778926588.991138", "card_id": "Q_7349267991", "feed_specific": {"answer_count": 72}, "target": {"title_area": {"text": "现在的小女孩为什么很少有戴发箍的了，原因是什么？"}, "excerpt_area": {"text": "我印象中，我是 00 年的，我那上小学，初中那时候，无论是身边的女同学还是同年龄段的女孩，那时候貌似都很喜欢扎马尾，头上戴发箍，看着也是很漂亮，而且五花八门的都有，尤其是很多喜欢带白色的，黑色的，粉色的，各种各样的都有。而且很多小女孩那个时候基本上都是天天戴发箍。 不过貌似在我 2015 年上了高中之后，生活当中就看到小学生初中生的小女孩很少有戴发箍的了，而且还是一年比一年少，到了快 2025 年了，我看现在的小女孩基本上没有戴发箍的了，反正在我这里是这样的，不知道别的地方怎么样... 而且发箍感觉以前只有小学生和初中生喜欢戴，到了上高中年龄大了基本上看不到了 所以说，现在上学的小女孩为什么很少有戴发箍的了？原因是什么呀？还有女孩年龄大了，为什么就不喜欢戴发箍了？原因是什么呀？"}, "image_area": {"url": "https://pic1.zhimg.com/80/v2-648a252e4dfde083bfbdd6c297906ab8_1440w.webp?source=1def8aca"}, "metrics_area": {"text": "58 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/7349267991"}}, "attached_info": "CkEIuPKh5JnQo4ZgEAMaCTExMjQ0NjU1MiDzjpO7BjAAONQBQBZyCjczNDkyNjc5OTF4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "23_1778926588.992203", "card_id": "Q_2035685308566610183", "feed_specific": {"answer_count": 151}, "target": {"title_area": {"text": "为什么我们总怪父母没抓住房产和互联网红利，可轮到自己面对 AI 时代红利时，也没好好抓住？"}, "excerpt_area": {"text": "在网上看到一句话，感叹万千：「这一刻突然懂了父亲当年的无奈，他站在改革开放的浪潮里，国家 GDP 翻了一百倍，可他为什么没赶上那班时代列车？如今我也站在 AI 浪潮下，大模型迭代不停，机会明明就在眼前，却抓不住风口。」 我们是不是错怪父母了？"}