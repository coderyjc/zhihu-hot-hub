nd": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2038563006892568719"}}, "attached_info": "CkkIxZTv5LjPpaJ2EAMaCTExOTUxMzg0NCCfg5rQBjAAOEdAF3ITMjAzODU2MzAwNjg5MjU2ODcxOXgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "24_1778937791.562256", "card_id": "Q_66774095", "feed_specific": {"answer_count": 66}, "target": {"title_area": {"text": "如何评价深圳首创的「移位左转」交通通行方式？"}, "excerpt_area": {"text": ""}, "image_area": {"url": "https://picx.zhimg.com/80/v2-5886ea6cb3fbc871e5ee7cf6b4a036c6_1440w.webp?source=1def8aca"}, "metrics_area": {"text": "104 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/66774095"}}, "attached_info": "Cj4IxZTv5LjPpaJ2EAMaCDE4OTM3MjgxIKejls8FMAA40AJAGHIINjY3NzQwOTV4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "25_1778937791.562532", "card_id": "Q_2038385138434663551", "feed_specific": {"answer_count": 18}, "target": {"title_area": {"text": "奔驰等多家德国车企计划裁员，未来累计流失岗位或达 22.5 万，背后都有哪些原因？可能给行业带来什么影响？"}, "excerpt_area": {"text": "据第一财经，德国汽车工业协会今日发布的一篇声明显示，德国汽车工业就业危机比预想的更为严峻。到 2035 年，面临流失风险的就业岗位，将比此前测算多出约 3.5 万个。 德国汽车工业协会与普罗诺斯经济研究所 2024 年发布的一项研究初步测算：在向气候中和交通转型进程中，相较于 2019 年基准，到 2035 年德国汽车行业或将流失约 19 万个就业岗位。究其原因，电动汽车的生产复杂度远低于燃油车，这也使得电动化转型必然伴随岗位流失，汽车零部件供应商领域受冲击尤为严重。而最新评估显示，到 2035 年行业累计流失岗位或将升至 22.5 万个。这 22.5 万个岗位缺口里，2019 至 2025 年间已有 10 万个岗位彻底消失。"}, "image_area": {"url": "https://pica.zhimg.com/80/v2-c365aadd6f76cf44659c8bbe399fa0ed_1440w.webp?source=1def8aca"}, "metrics_area": {"text": "103 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2038385138434663551"}}, "attached_info": "CkkI