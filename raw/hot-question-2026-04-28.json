3b718e0531cb7d3a_1440w.png", "night_icon": "https://pic3.zhimg.com/80/v2-c89199839c237b87e52f010bb5e7d773_1440w.png"}, "feed_specific": {"answer_count": 55}, "target": {"title_area": {"text": "伊朗外长抵达圣彼得堡将同普京举行会谈，会谈些啥？美伊局势转向会迎来重要契机吗？"}, "excerpt_area": {"text": "据伊朗媒体 27 日报道，伊朗外长阿拉格齐当天凌晨抵达俄罗斯圣彼得堡，将同俄罗斯总统普京举行会谈。新华社分享页"}, "image_area": {"url": "https://pic1.zhimg.com/v2-cf6349fe971990d6aa31020d7fb310c4.png"}, "metrics_area": {"text": "158 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2032051759590397567"}}, "attached_info": "CkoI2byb/M2LroICEAMaCTExOTI5NzI0NiCNo7vPBjAAOI4BQAVyEzIwMzIwNTE3NTk1OTAzOTc1Njd4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "6_1777307210.783836", "card_id": "Q_2031385695172940391", "card_label": {"type": "hot", "icon": "https://pic2.zhimg.com/80/v2-266e83dbee46dce23b718e0531cb7d3a_1440w.png", "night_icon": "https://pic3.zhimg.com/80/v2-c89199839c237b87e52f010bb5e7d773_1440w.png"}, "feed_specific": {"answer_count": 98}, "target": {"title_area": {"text": "火葬场领取亲人骨灰，会混杂了很多别人的骨灰吗？"}, "excerpt_area": {"text": "也就是说，领取骨灰安葬进祖坟的子孙们，其实世世代代虔诚地供奉着别人身体的一部分，并且很可能不止 1 个「别人」，十几个都有可能。 一个火葬场工作人员说：普通烧法就是炉子里剩着上个人烧的灰，烧完铲出来也会留下一部分在炉里，装骨灰的时候也不一定全装进去，烧不碎的大骨头用锤子砸成小块塞骨灰盒里，塞差不多的倒骨灰进去，装满了再把头骨放上面，装不下的灰（骨头块）就剩在炉子里头不管了。 有人打了个绝妙的比方：卖肉馅的，绞肉机出口那块永远是上一个人买的，而自己买那块尾巴也永远得不到。 …以及，其实大部分尸体质量是变成气体和粉尘，早就从烟囱飘去了大气，离开了爱他的亲友们，领取骨灰只是走个流程罢了。"}, "image_area": {"url": "https://picx.zhimg.com/v2-1c5cb7632f78691dd86d678254f4a2f8_qhd.jpg?source=57bbeac9"}, "metrics_area": {"text": "157 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2031385695172940391"}}, "attached_info": "CkoI2byb/M2LroICEAMaCTExOTI3ODUwMCC7yrHPBjAAOMABQAZyEzIwMzEzODU2OTUxNzI5NDAzOTF4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "7_1777307210.784651", "card_id": "Q_2030297015276549260", "feed_specific": {"answer_count": 150}, "target": {"title_area": {"text": "我没有编程能力，现在写了完整的游戏设计文稿，并准备了 20 万资金，想把游戏用 AI 做出来，该怎么做？"}, "excerpt_area": {"text": "游戏的内容、规则和大致玩法我已经定稿，输入 ai 使其完全理解以后，输出了执行框架和内容模块。目前在思考怎么用 ai 接入 unity 做 demo，也考虑招人外包，头绪太多，执行起来非常困难，请知乎的大神指导我"}, "image_area": {"url": "https://pic1.zhimg.com/50/v2-03b307541e4a2afc914a3e4b0a31bd3e_b.jpg"}, "metrics_area": {"text": "157 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2030297015276549260"}}, "attached_info": "CkoI2byb/M2LroICEAMaCTExOTIzODQyMyDR3qHPBjAAONcDQAdyEzIwMzAyOTcwMTUyNzY1NDkyNjB4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "8_1777307210.785301", "card_id": "Q_54694619", "card_label": {"type": "hot", "icon": "https://pic2.zhimg.com/80/v2-266e83dbee46dce23b718e0531cb7d3a_1440w.png", "night_icon": "https://pic3.zhimg.com/80/v2-c89199839c237b87e52f010bb5e7d773_1440w.png"}, "feed_specific": {"answer_count": 140}, "target": {"title_area": {"text": "为什么吕后把戚夫人做成人彘后，非要强迫自己的儿子汉惠帝去看？"}, "excerpt_area": {"text": "结果汉惠帝胆小，居然惊吓成疾，没多久就死了年仅二十三岁。 我觉得这种事情藏着都来不及，结果吕后不但不避讳还要故意逼儿子去看，是出于什么心理？"}, "image_area": {"url": "https://pica.zhimg.com/100/v2-06eb603b08ce255a271b4e700c2d7ed8_r.jpg"}, "metrics_area": {"text": "150 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/54694619"}}, "attached_info": "Cj4I2byb/M2LroICEAMaCDE0MDk3OTM1IInL3cMFMAA4zwVACHIINTQ2OTQ2MTl4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "9_1777307210.785863", "card_id": "Q_56376363", "card_label": {"type": "hot", "icon": "https://pic2.zhimg.com/80/v2-266e83dbee46dce23b718e0531cb7d3a_1440w.png", "night_icon": "https://pic3.zhimg.com/80/v2-c89199839c237b87e52f010bb5e7d773_1440w.png"}, "feed_specific": {"answer_count": 61}, "target": {"title_area": {"text": "中国茶叶农残为什么严重？"}, "excerpt_area": {"text": "全球性环保组织【绿色和平】对 15 个茶品牌下的 26 份茶叶样品，进行了农药残留指标的检测，结果显示只有 1 个符合国标，超过半数抽检样品——例如张一元、吴裕泰、竹叶青、天福茗茶等抽检样品都被查出含有国家禁用农药，大部分样品都不符合欧盟设定的标准。 中国茶叶农残为什么得不到根本性改善？"}, "image_area": {"url": "https://picx.zhimg.com/80/v2-e45c14e71d8c653db13db5987828a81e_720w.webp?source=1def8aca"}, "metrics_area": {"text": "146 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/56376363"}}, "attached_info": "Cj4I2byb/M2LroICEAMaCDE0NzcwOTc0IPHlzsUFMAA4xgFACXIINTYzNzYzNjN4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "10_1777307210.786361", "card_id": "Q_2031863204075106462", "card_label": {"type": "hot", "icon": "https://pic2.zhimg.com/80/v2-266e83dbee46dce23b718e0531cb7d3a_1440w.png", "night_icon": "https://pic3.zhimg.com/80/v2-c89199839c237b87e52f010bb5e7d773_1440w.png"}, "feed_specific": {"answer_count": 53}, "target": {"title_area": {"text": "美以袭击伊朗进入第 59 天，当前局势如何？还有哪些信息值得关注？"}, "excerpt_area": {"text": ""}, "image_area": {"url": "https://picx.zhimg.com/80/v2-3e8295a44011b77885f8f6f59f478891_720w.webp?source=1def8aca"}, "metrics_area": {"text": "145 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2031863204075106462"}}, "attached_info": "CkkI2byb/M2LroICEAMaCTExOTI5MzEzMyDyw7jPBjAAOHhACnITMjAzMTg2MzIwNDA3NTEwNjQ2MngAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "11_1777307210.786623", "card_id": "Q_2031014158049567038", "feed_specific": {"answer_count": 27}, "target": {"title_area": {"text": "2026 青岛马拉松有选手边跑边跳绳，如何评价这种行为？官方禁赛 2 年，罚重了吗？"}, "excerpt_area": {"text": "4 月 23 日晚，青岛国际马拉松发布公告，对 4 月 19 日进行的 2026 年青岛马拉松比赛中 16 名违规人员发布处罚。其中一位选手边跳绳边跑，被处以禁赛 2 年，引发热议。 处罚公告显示，本届青岛马拉松存在替跑蹭跑、私自转让出售号码布、伪造参赛证件、遮挡号码布、赛道携带旗杆道具、奔跑中干扰其他选手等多种严重问题，其中多名存在转让、伪造号码布的选手，直接被处以终身禁赛，并上报中国田协备案。 其中 16 名违规者中，一名参赛选手全程手持跳绳，在赛道上边跑边跳绳完成比赛，最终以 3 小时 50 分 05 秒完赛。赛事组委会核查赛事全程监控后判定，其持器械奔跑极易剐蹭、阻挡周边跑者，比赛期间存在干扰其他参赛选手行为，存在极大安全隐患。最终官方作出处罚：取消本次全马成绩与排名，禁止参加 2026-2027 年青岛马拉松组委会举办的各项赛事，违规档案同步上报田协备案。青岛马拉松有人边跑边跳绳，官方：禁赛 2 年 _ 腾讯新闻"}, "image_area": {"url": "https://pic1.zhimg.com/80/v2-e999dff9fc365c413448e62de5e6c9ee_720w.webp?source=1def8aca"}, "metrics_area": {"text": "143 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2031014158049567038"}}, "attached_info": "CkkI2byb/M2LroICEAMaCTExOTI2NTkyNSC1lqzPBjAAODhAC3ITMjAzMTAxNDE1ODA0OTU2NzAzOHgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "12_1777307210.787418", "card_id": "Q_35190585", "feed_specific": {"answer_count": 383}, "target": {"title_area": {"text": "数码宝贝（第一季）里的太一为什么能当领头大哥？"}, "excerpt_area": {"text": ""}, "image_area": {"url": "https://pic3.zhimg.com/80/v2-36d02a9deee62d5cbc1f2d2ce17ee310_720w.webp"}, "metrics_area": {"text": "132 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/35190585"}}, "attached_info": "Cj0I2byb/M2LroICEAMaBzYyODI5MTYg6O6OrwUwADieBUAMcggzNTE5MDU4NXgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "13_1777307210.787717", "card_id": "Q_2032028410440934664", "card_label": {"type": "hot", "icon": "https://pic2.zhimg.com/80/v2-266e83dbee46dce23b718e0531cb7d3a_1440w.png", "night_icon": "https://pic3.zhimg.com/80/v2-c89199839c237b87e52f010bb5e7d773_1440w.png"}, "feed_specific": {"answer_count": 25}, "target": {"title_area": {"text": "2859.2 克黄金制品被警方扣押三十年，律师称双方和解可能性很大，若和解当事人能拿到多少赔偿？"}, "excerpt_area": {"text": "日前，经媒体报道登上热搜的「2859.2 克黄金制品被公安扣押三十年」一事有新进展。据了解，1996 年 5 月，辽宁省瓦房店市男子潘永嘉购买 2859.2 克黄金制品（18k 金，黄金含量 75%）后，被辽宁省营口市盖州市公安局以涉嫌走私犯罪为由扣押。4 月 26 日，新京报记者从潘永嘉代理律师张铁雁处获悉，4 月 25 日，盖州市公安局主动与他取得联系，询问潘永嘉的要求，双方已约定见面沟通赔偿事宜，「和解的可能性很大。」 张铁雁告诉新京报记者，他对盖州市公安局表示，希望当事人能按照国家赔偿法的有关规定获得公正赔偿。 1996 年 5 月 6 日，潘永嘉购买了 2859.2 克黄金制品，在大连周水子机场被盖州市公安局以涉嫌走私犯罪抓获，黄金制品被盖州市公安局扣押。潘永嘉被收容审查 11 天，家人缴纳 5 万元保证金后，潘永嘉被取保候审。 盖州市公安局扣押物品清单显示，扣押物品为黄色 18k 金项链、金坠，合计 2859.2 克，21 包。潘永嘉家属告诉新京报记者，当时黄金价格低，潘永嘉买这些金首饰是想留些资产，「有 18k 金的，也有 24k 金的。」 此后，潘永嘉多次向盖州市公安局询问案件调查进展和被扣押黄金的下落，但都没有得到确切回复。至今，盖州市公安局未对潘永嘉作有罪认定、未处置扣押黄金、未返还保证金。 2026 年 1 月，距离黄金被扣押已经过了 30 年，76 岁的潘永嘉向盖州市公安局提出刑事赔偿申请，被盖州市公安局以超过请求时效、不符合申请条件为由作出不予受理决定。 潘永嘉不服，向营口市公安局申请复议。2026 年 3 月，潘永嘉在提交给营口市公安局的《刑事赔偿复议申请补充材料》中称，盖州市公安局违法扣押黄金制品的行为符合《中华人民共和国国家赔偿法》第十八条规定，应优先原物返还；若黄金制品已被处置，需按本决定作出当日上海黄金交易所金价赔偿。潘永嘉未被追究刑事责任，赔偿义务机关无合法依据占用 5 万元保证金，依法应予全额退还。 张铁雁表示，除了黄金制品和保证金，潘永嘉要求的赔偿还包括从 1996 年 5 月 6 日至今的利息。此外，潘永嘉被限制人身自由 11 天，涉及人身损害赔偿金问题，盖州市公安局还应为潘永嘉消除影响、恢复名誉。2859.2 克黄金制品被警方扣押三十年：公安已约当事人面谈 4 月 27 日，当事人潘永嘉的代理律师张铁雁告诉红星新闻记者，当地警方已约定 28 日上午见面沟通赔偿事宜。 27 日下午，盖州市公安局工作人员对红星新闻记者表示，该局此前做了不予受理决定，当事人申请了复议，目前正按复议程序推进。「当事人的利益应该保证，我们非常重视此事，会按正常的时效处理，回应社会关切。」警方回应「2859 克黄金被扣押 30 年申请退赔遭拒」：很重视，正按复议程序推进"}, "image_area": {"url": "https://pic2.zhimg.com/50/v2-c93f8036a8c022d4e23c2ec5d560f013_b.jpg"}, "metrics_area": {"text": "121 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2032028410440934664"}}, "attached_info": "CkkI2byb/M2LroICEAMaCTExOTI5NjA3NSDO97rPBjAAODxADXITMjAzMjAyODQxMDQ0MDkzNDY2NHgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "14_1777307210.789383", "card_id": "Q_460929815", "feed_specific": {"answer_count": 43}, "target": {"title_area": {"text": "如果说王菲当年进击欧美乐坛，那她会创造出怎样的成绩？"}, "excerpt_area": {"text": "她在 92 年不是从美国进修回来，发了张 coming home 么？如果她那个时候呆在美国进军欧美市场？跟李玟一样？ 李玟连华语乐坛都征服不了，当然也征服不了欧美乐坛。可是王菲不一样啊，她可是征服了华语乐坛的中国第一女歌手啊。"}, "image_area": {"url": "https://picx.zhimg.com/80/v2-e80d73769a6e28b98cedf1b0eacbc2a1_720w.webp?source=1def8aca"}, "metrics_area": {"text": "118 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/460929815"}}, "attached_info": "Cj4I2byb/M2LroICEAMaCDY0NzA4NTAwIKPPpoUGMAA4RkAOcgk0NjA5Mjk4MTV4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "15_1777307210.790009", "card_id": "Q_2030646477731489020", "feed_specific": {"answer_count": 38}, "target": {"title_area": {"text": "马鞍山一中学多名学生研学就餐后拉肚子，有孩子称吃的鸡腿是臭的，官方通报涉事酒店停业整顿，具体情况如何？"}, "excerpt_area": {"text": "马鞍山市市场监督管理局 4 月 23 日通报：4 月 20 日，马鞍山第七中学九年级学生前往当涂县大青山野生动物园开展春季研学活动，期间在当涂县矿坑生态酒店集中午餐。活动结束后，部分学生出现腹痛腹泻症状。‌ 事情发生后，马鞍山市食品药品安全委员会办公室立即组织当涂县、花山区、市教育局、市卫健委、市市场监管局等相关单位，第一时间安排就医，同步开展流调、采样、检测及食品安全溯源。经初步核查，腹痛腹泻原因为食源性疾病，致病原为产气荚膜梭菌。截至 4 月 23 日，33 名确诊病例学生全部康复并返校复课。 日前，马鞍山市食品药品安全委员会办公室已责令当涂县对该酒店下达停业整顿通知书，并就食品加工违法线索立案查处，后续将根据调查结果，依法依规对涉事酒店严肃处理。 下一步，市监局将举一反三，加大日常监管力度，坚决防止类似事件再次发生。马鞍山一中学多名学生研学就餐后腹痛腹泻，官方：涉事酒店停业整顿 4 月 23 日，安徽马鞍山第七中学多名家长反映，20 日该校组织初三年级学生到大青山动物园研学，中午吃过盒饭后，许多学生喊肚子疼，疑似食物中毒。23 日，极目新闻记者从马鞍山当涂县市场监督管理局获悉，该局正在调查，已将涉事酒店的盒饭送检。 学生中午吃的盒饭 一位家长表示，4 月 20 日，孩子参加了学校组织的春游活动，前往大青山动物园进行一日游。当天中午吃了一份集体供应的盒饭，晚上回来之后开始喊肚子疼，接着就是拉肚子，跑了一晚上的厕所，早上被医生诊断是急性肠胃炎。 该家长说，她先以为是天气骤凉引起孩子肠胃不适，第二天看到家长群里都在反映孩子春游回来拉肚子，才开始怀疑是食物中毒。 家长的聊天记录 该家长发布的一张家长群聊天记录中，有家长称，孩子回来后当天晚上拉了四次肚子，班上有二十几个同学拉肚子，听说其他班上也有一些学生中招。 另有一位家长告诉极目新闻记者，该校这次是以研学名义，组织初三学生到当涂县大青山动物园玩一天，每名学生收费 180 元。20 日中午，学生吃的是当地一家酒店提供的盒饭。「没想到这么多人拉肚子，有孩子说当天中午吃的盒饭里面鸡腿是馊的，还有的说鸡腿是臭的。」 23 日，极目新闻记者拨打马鞍山第七中学公开电话，无人接听。记者电话咨询该校所在的马鞍山市花山区市场监督管理局，一工作人员称，已接到多位家长反映马鞍山第七中学学生疑似食物中毒一事，目前该事件由当涂县市市场监督管理局在调查。 随后，极目新闻记者电话联系到当涂县市场监督管理局，一工作人员表示，目前该局正在调查原因，已将涉事酒店的盒饭送到县卫健委相关部门进行检测。 23 日，极目新闻记者从当涂县卫健委获悉，样品已委托疾控部门进行检测，目前还没有出结果。 23 日，极目新闻记者致电马鞍山花山区教育局，一工作人员称，目前信访办正在处理此事。马鞍山一中学多名学生研学就餐后反复拉肚子，有孩子称「吃的鸡腿是臭的」，当地介入调查"}, "image_area": {"url": "https://pic1.zhimg.com/80/v2-80739a1ddccdf72c98e4945302d5f208_720w.webp?source=1def8aca"}, "metrics_area": {"text": "117 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2030646477731489020"}}, "attached_info": "CkkI2byb/M2LroICEAMaCTExOTI1MTE0OSDH6abPBjAAOE5AD3ITMjAzMDY0NjQ3NzczMTQ4OTAyMHgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "16_1777307210.793780", "card_id": "Q_2030445160417510538", "feed_specific": {"answer_count": 30}, "target": {"title_area": {"text": "如何评价小米 4 月 23 日发布的 MiMo-V2.5 系列模型，有可能比 DeepSeekV4 更强吗？"}, "excerpt_area": {"text": ""}, "image_area": {"url": "https://picx.zhimg.com/80/v2-4571a91d4894d2fb93f7fdd9c2e4cd8c_720w.webp?source=1def8aca"}, "metrics_area": {"text": "115 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2030445160417510538"}}, "attached_info": "CkkI2byb/M2LroICEAMaCTExOTI0NDU1MSDK8qPPBjAAOEpAEHITMjAzMDQ0NTE2MDQxNzUxMDUzOHgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "17_1777307210.794860", "card_id": "Q_2031819380355502254", "feed_specific": {"answer_count": 17}, "target": {"title_area": {"text": "网购、外卖、出行频繁捆绑信贷分期，八部门出台新规全面整治，白条、月付面临调整，释放了哪些监管信号？"}, "excerpt_area": {"text": "长期以来，在电商、外卖、出行、生活缴费等日常消费场景中，「白条」「月付」等信贷分期类产品常常与银行卡、账户余额等常规支付工具并列展示，部分平台还存在默认勾选、弹窗推送、前置推荐等操作，用户稍不留意便会被动开通或使用信贷服务。 大量消费者投诉反映，在未充分知情、未明确了解信贷属性的前提下，被动开通或使用分期服务，甚至出现逾期后才知晓存在借贷的情况，消费者权益受侵害问题频发。 如今，信贷过度嵌入日常消费场景的现实困局，终于有解了。日前，中国人民银行等八部门联合印发《金融产品网络营销管理办法》（以下简称《办法》），针对非银行支付机构的支付嵌入信贷乱象，《办法》第十二条划出明确红线：非银行支付机构不得将贷款、资产管理产品等金融产品列入支付工具选项，不得为贷款、资产管理产品等金融产品提供营销服务。《办法》自 2026 年 9 月 30 日起正式施行。 一些业内人士在受访时对《每日经济新闻》记者表示，这