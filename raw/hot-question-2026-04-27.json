df26c961f738788_b.jpg"}, "metrics_area": {"text": "296 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2031411061107208300"}}, "attached_info": "CkoI9/vfkdDApJwlEAMaCTExOTI3OTM1MSDa+bHPBjAAOLIBQAFyEzIwMzE0MTEwNjExMDcyMDgzMDB4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "2_1777278427.717590", "card_id": "Q_2029619111450222998", "feed_specific": {"answer_count": 125}, "target": {"title_area": {"text": "研究生坐六小时成「发呆比赛」冠军，落泪称「多次想放弃，坚持不容易」，全程不玩手机不交谈，这比赛有多难？"}, "excerpt_area": {"text": "4 月 18 日，四川眉山丹棱幸福古村举办首届发呆大赛。 现场 46 名参赛者从下午 1 点静坐至日落，全程禁止玩手机、交谈、嬉笑，闭眼时长也不能超过 10 秒。 主办方告诉记者，快节奏生活下慢下来已成奢侈，举办比赛并非猎奇，而是希望让更多人知道，发呆是可以光明正大的，放空是被允许的。"}, "image_area": {"url": "https://pic1.zhimg.com/v2-a011a1df0db3b13acf4849b5858ad717.png"}, "metrics_area": {"text": "  ", "font_color": "GBK06A", "background": "GBK06A", "weight": "BOLD"}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2029619111450222998"}}, "attached_info": "CkoI9/vfkdDApJwlEAMaCTExOTIxNDkzNiD475fPBjAAOIACQAJyEzIwMjk2MTkxMTE0NTAyMjI5OTh4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "3_1777278427.718393", "card_id": "Q_2031783897910990078", "card_label": {"type": "hot", "icon": "https://pic2.zhimg.com/80/v2-266e83dbee46dce23b718e0531cb7d3a_1440w.png", "night_icon": "https://pic3.zhimg.com/80/v2-c89199839c237b87e52f010bb5e7d773_1440w.png"}, "feed_specific": {"answer_count": 23}, "target": {"title_area": {"text": "余承东新产品定价比小米便宜 100 元，这种策略能否持续奏效？"}, "excerpt_area": {"text": "余承东最后的倔强：比小米便宜 100 块，然后呢？"}, "image_area": {"url": "https://picx.zhimg.com/80/v2-6bf3f143cafd12692c25109d012e296c_720w.webp?source=1def8aca"}, "metrics_area": {"text": "186 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2031783897910990078"}}, "attached_info": "CkkI9/vfkdDApJwlEAMaCTExOTI5MDUyNiCVsLfPBjAAOCFAA3ITMjAzMTc4Mzg5NzkxMDk5MDA3OHgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "4_1777278427.718940", "card_id": "Q_2032056046093591144", "feed_specific": {"answer_count": 254}, "target": {"title_area": {"text": "如何评价鲁超济南队夏雨荷啦啦队遭群嘲？"}, "excerpt_area": {"text": "[图片]"}, "image_area": {"url": "https://picx.zhimg.com/v2-8dbba4cfa92a1b0b244d49a505b8ac0b.jpeg"}, "metrics_area": {"text": "175 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2032056046093591144"}}, "attached_info": "CkoI9/vfkdDApJwlEAMaCTExOTI5ODE5MCCLq7vPBjAAOKYCQARyEzIwMzIwNTYwNDYwOTM1OTExNDR4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "5_1777278427.719273", "card_id": "Q_2031995592310616152", "feed_specific": {"answer_count": 157}, "target": {"title_area": {"text": "伊朗递交停战条件，并提出一项分三阶段解决的谈判方案，与此前内容有哪些变化？美方接受可能性有多大？"}, "excerpt_area": {"text": "△伊朗外长阿拉格齐（左） 当地时间 4 月 26 日，在结束对阿曼为期一天的访问后，伊朗外长阿拉格齐抵达巴基斯坦伊斯兰堡。 根据伊朗外交部消息，按照预定计划，阿拉格齐将在伊斯兰堡短暂停留，随后继续前往俄罗斯。阿拉格齐在巴基斯坦的短暂停留期间，将与巴基斯坦官员就最新的地区和国际局势进行交流。 除了双边关系的对话外，伊朗外长阿拉格齐此行的重要议程之一是向作为调解国的巴基斯坦传达伊朗结束战争的条件。阿拉格齐提出的议题包括对霍尔木兹海峡实施新的法律制度、索赔、确保战争挑衅者不再发动军事侵略、解除海上封锁等，这些谈判与核问题无关。 阿拉格齐在访问中，通过巴基斯坦向美方传递了书面信息；这些信息涉及伊朗的一些红线问题，包括核问题和霍尔木兹海峡。 阿拉格齐于 25 日晚间抵达阿曼首都马斯喀特进行访问。在结束对阿曼的访问后并在前往俄罗斯之前，他按计划再次访问巴基斯坦。 阿拉格齐 24 日在社交平台发消息称，他将访问巴基斯坦、阿曼和俄罗斯。伊朗外长抵达伊斯兰堡 向巴基斯坦递交停战条件 总台记者 27 日获悉，伊朗方面消息人士称，伊朗已通过中间人向美方传达了一个三阶段谈判方案。 谈判第一阶段的重点是彻底结束战争，并获得防止对伊朗和黎巴嫩重新发动战争的保证。如果在第一阶段达成协议，各方将进入第二阶段，该阶段将专门研究霍尔木兹海峡如何管理的问题。第三阶段与核问题讨论有关，但在前两个阶段达成协议之前，伊朗绝不会参与核问题谈判。伊朗提出一项分三阶段解决的谈判方案"}, "image_area": {"url": "https://pic1.zhimg.com/v2-0ad04e0570a715827b0140e16e196b46_1440w.jpg"}, "metrics_area": {"text": "169 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2031995592310616152"}}, "attached_info": "CkoI9/vfkdDApJwlEAMaCTExOTI5NTA2NSC9urrPBjAAONkCQAVyEzIwMzE5OTU1OTIzMTA2MTYxNTJ4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "6_1777278427.720656", "card_id": "Q_2028446688520480394", "feed_specific": {"answer_count": 129}, "target": {"title_area": {"text": "儿子四年级，我让他退掉了所有补习班，朋友说我躺平了，我错了吗？"}, "excerpt_area": {"text": "我儿子现在四年级，其实从幼儿园开始他就一直在上各种补习班，从一开始英语，到后面钢琴，围棋，画画，乒乓，奥数，机器人，长笛，因为各种各样的原因有些都中断了，现在就只剩长笛了，朋友跟我讨论的时候说我现在太躺平了，万一他哪天长大了，怪我现在没逼他一把，说他本可以更好的，我该怎么办？"}, "image_area": {"url": "https://picx.zhimg.com/80/v2-8cd7f1b83a5be4dd5815e5c769e705b5_1440w.webp?source=1def8aca"}, "metrics_area": {"text": "166 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2028446688520480394"}}, "attached_info": "CkoI9/vfkdDApJwlEAMaCTExOTE3NzEwMiCR6IbPBjAAOMkBQAZyEzIwMjg0NDY2ODg1MjA0ODAzOTR4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "7_1777278427.721680", "card_id": "Q_2031063421152646919", "feed_specific": {"answer_count": 128}, "target": {"title_area": {"text": "旅客带娃买高铁票却被分到相隔 14 个车厢的座位，铁路部门应如何改进购票系统以避免此类问题？"}, "excerpt_area": {"text": "家长带着孩子买高铁票，座位被分配到 1 车和 16 车，中间相隔 14 个车厢不说，且因为是重联列车，8 、 9 车之间并不相通，两人被完全阻隔…近日，四川旅客芳芳就遇到了这样的窘境。4 月 24 日，铁路 12306 客服表示，当余票不足时，家长和儿童的座位才会被分开。旅客遇到这种情况时，可在上车后协商换座。 封面新闻带娃买高铁票结果相隔 14 个车厢"}, "image_area": {"url": "https://pic3.zhimg.com/v2-d50902a223a4380dcb671897fba8baa2_1440w.png"}, "metrics_area": {"text": "163 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2031063421152646919"}}, "attached_info": "CkoI9/vfkdDApJwlEAMaCTExOTI2ODE1NiCW8qzPBjAAOKEBQAdyEzIwMzEwNjM0MjExNTI2NDY5MTl4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "8_1777278427.722696", "card_id": "Q_2030953856360820901", "feed_specific": {"answer_count": 151}, "target": {"title_area": {"text": "小米 YU7 GT 超千匹马力、 300 km/h 最高时速，SUV 做到这水平有必要吗？可能怎样定价？"}, "excerpt_area": {"text": "4 月 24 日上午消息，2026 北京车展今日开幕，在小米汽车发布会上，小米集团董事长、 CEO 雷军发表演讲。 他透露，小米 YU7 GT 将于今年 5 月底发布，定位是适合长途旅行的高性能 SUV。提前预告了小米 YU7 GT 的一些参数，1003 PS 最大马力，300km/h 最高时速，705km CLTC 续航。"}, "image_area": {"url": "https://pic1.zhimg.com/v2-fa82590eb4cccc74125442248220bcfe.png"}, "metrics_area": {"text": "152 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2030953856360820901"}}, "attached_info": "CkoI9/vfkdDApJwlEAMaCTExOTI2MTg0MiCMpqvPBjAAOM0BQAhyEzIwMzA5NTM4NTYzNjA4MjA5MDF4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "9_1777278427.723337", "card_id": "Q_22154852", "feed_specific": {"answer_count": 22}, "target": {"title_area": {"text": "卧室养很多花的话晚上睡觉会跟人抢氧气吗？长期如此对身体有害吗？"}, "excerpt_area": {"text": ""}, "image_area": {"url": "https://pic1.zhimg.com/80/v2-ca420bf472d93743c0f0316ff92089ec_720w.webp?source=1def8aca"}, "metrics_area": {"text": "149 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/22154852"}}, "attached_info": "CjwI9/vfkdDApJwlEAMaBzEwNDI3OTgg1rnnlAUwADg/QAlyCDIyMTU0ODUyeACqAQliaWxsYm9hcmTSAQA="}, {"type": "hot_list_feed", "style_type": "1", "id": "10_1777278427.723668", "card_id": "Q_2032052994884071504", "feed_specific": {"answer_count": 94}, "target": {"title_area": {"text": "追觅 CEO 连续发文炮轰小红书是非常非常烂的平台，称其肆意推送各种未经证实的假消息，究竟是怎么回事？"}, "excerpt_area": {"text": "4 月 27 日，据中国蓝新闻消息，26 日，追觅科技创始人兼 CEO 俞浩连发三条微博炮轰小红书，直言小红书「是一个非常非常烂的平台」，社会价值观导向「非常非常烂」。「这并不是我们近期有啥小红书舆情了，而是我观察一段时间之后的结论。」俞浩直言，「任何在小红书上评论我们产品的，基本都不要信！反正我也不会把那上面的任何反馈信息当参考，就是一个价值观和盈利模式都非常有毒的平台！」 随后，其又补发博文道：「我们起诉每一个在小红书上造谣的博主时，都应该连带小红书平台一起起诉！大家就是害怕这个平台，才导致这个平台如此肆意推送各种未经证实的假消息，肆意妄为！」 他还在评论区补充：「小红书的算法是有意推荐做恶的。」 追觅 CEO 连续发文炮轰小红书，「非常非常烂的平台」：肆意推送各种未经证实的假消息"}, "image_area": {"url": "https://picx.zhimg.com/50/v2-377e0ef9663910ac4228673510118c47_b.jpg"}, "metrics_area": {"text": "147 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2032052994884071504"}}, "attached_info": "CkoI9/vfkdDApJwlEAMaCTExOTI5NzU2MCCzpbvPBjAAOJ8BQApyEzIwMzIwNTI5OTQ4ODQwNzE1MDR4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "11_1777278427.724587", "card_id": "Q_2025891672446247195", "feed_specific": {"answer_count": 54}, "target": {"title_area": {"text": "网上流行的「超慢跑」减肥法，宣称比走路还慢却能高效燃脂，这真的有用吗？它的燃脂效果究竟如何？"}, "excerpt_area": {"text": ""}, "image_area": {"url": "https://pic1.zhimg.com/v2-c8aa61b3cf62a771e339a5bdbdbe14ae.png"}, "metrics_area": {"text": "146 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2025891672446247195"}}, "attached_info": "CkoI9/vfkdDApJwlEAMaCTExOTA4ODE2MCCF0eHOBjAAOI4CQAtyEzIwMjU4OTE2NzI0NDYyNDcxOTV4AKoBCWJpbGxib2FyZNIBAA=="}, {"type": "hot_list_feed", "style_type": "1", "id": "12_1777278427.724826", "card_id": "Q_1907346366218364805", "card_label": {"type": "hot", "icon": "https://pic2.zhimg.com/80/v2-266e83dbee46dce23b718e0531cb7d3a_1440w.png", "night_icon": "https://pic3.zhimg.com/80/v2-c89199839c237b87e52f010bb5e7d773_1440w.png"}, "feed_specific": {"answer_count": 40}, "target": {"title_area": {"text": "第一次试了 1 小时乒乓球教练，发现正手攻球动作不标准，让我不要和其他人打球，是合理的吗? 还是为了赚我钱？"}, "excerpt_area": {"text": "按照标准动作，有提到大臂不应该外展，然后重心必须前倾，用脚找球，拍型 70 度左右能接所有球，但是暂时不要和其他人打球了，会毁动作，大家看看有理不？"}, "image_area": {"url": "https://picx.zhimg.com/v2-865da7894c54cddfdb046100548c16fa.png"}, "metrics_area": {"text": "145 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/1907346366218364805"}}, "attached_info": "CkkI9/vfkdDApJwlEAMaCTExNDk4ODA3NCCayaTBBjAAOFlADHITMTkwNzM0NjM2NjIxODM2NDgwNXgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "13_1777278427.725169", "card_id": "Q_2031382043821434628", "card_label": {"type": "hot", "icon": "https://pic2.zhimg.com/80/v2-266e83dbee46dce23b718e0531cb7d3a_1440w.png", "night_icon": "https://pic3.zhimg.com/80/v2-c89199839c237b87e52f010bb5e7d773_1440w.png"}, "feed_specific": {"answer_count": 63}, "target": {"title_area": {"text": "男子花 21999 元网购三星手机，被要求激活才能签收，客服称为防黄牛倒卖，这要求合法吗？算不算霸王条款？"}, "excerpt_area": {"text": "「网上买了手机，必须当场激活才能签收？」「我付了钱，不能自己决定什么时候激活吗？」 网上买手机，是如今很多人都会选择的方式。方便快捷、送货上门，时常有补贴，好处有很多。但有时候，网购还附加了一些特殊条件，让消费者直呼「太不合理」。 近日，读者吴先生向潮新闻投诉，自己网购了一台三星手机，却被告知要激活才能签收，为什么会这样？这算不算霸王条款？对此，记者进行多方采访寻找答案。 原价网购的手机 不激活不让签收 最近，杭州市民吴先生遇到了一个麻烦事，他在某平台的三星官方旗舰店上下单了一台三星三折叠手机，三星 Galaxy Z TriFold 的 1TB 款，售价 21999 元，他直接付款。 没想到，几天后快递送货上门，但快递小哥告诉他，必须当面激活才能签收。 吴先生心生疑惑，自己没有用任何优惠和国家补贴，为啥一定要立即激活手机？既然已经付了钱，货也到手了，自己有权利不激活，万一日后还要送人，也不方便激活。 随后，他又去咨询了官方旗舰店的客服，对方给的解释是，三星这款比较贵重，必须要激活才能签收，要防止黄牛以高价转手。如客户不希望激活签收，可以购买其他产品。 受访者 供图 在平台旗舰店的页面上，记者看见，这款三折叠手机每天上午十点限量发售，宣传图底部有一行小字：需配合完成现场开机激活后可签收，手机激活不可退。 「这简直就是霸王条款。不激活就不能签收，商家可以随意制定这种附加条件吗？」吴先生愤愤不平地发问。 记者咨询了三星旗舰店客服，对方给的回答是：「防止黄牛倒卖，这款三折叠手机需要激活才能签收。」除此之外，需要当面激活的还有用国补购买的手机，这是按照国家规定来做的。 「国补的手机，要当场激活验证，我非常理解，不然的话，有人会薅羊毛。但一个非国补的产品也要强制激活，这不合理吧？」吴先生说。 4 月 24 日，记者前往杭州一三星手机门店，现场销售人员说，这款三折叠手机是限量款，库存有限，必须要当场激活。 何泠瑶 摄 「如果直接买已激活款的，可以拿到补贴消费券，比原价便宜 1000 块。但补贴活动时间有限，到 5 月份就结束了。」店员说，自从去年 12 月上市以来，这款就卖得很好。 不仅是这一款三折叠手机要激活，还有 S26 的全系都需要当场激活，买已激活款和非激活款，价格约相差 500-1000 元不等。 杭州一位手机渠道商告诉记者，不只是三星，部分其他品牌也有这种「不成文」的规定。 「卖一些热门款式手机，必须当场立即激活，门店会有考核激活率，只有激活的，才算销量。而且，卖一台已激活的手机，往往要比不激活的便宜几百到上千元。」他说。 对此，吴先生说：「防黄牛的这个出发点，我十分理解，但手机厂商不应该把防黄牛的责任和义务转移到普通消费者头上。」"}, "image_area": {"url": "https://pic4.zhimg.com/50/v2-ece882a0ddb2c139a305005047b729d5_b.jpg"}, "metrics_area": {"text": "115 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2031382043821434628"}}, "attached_info": "CkkI9/vfkdDApJwlEAMaCTExOTI3ODQxMSDUw7HPBjAAODtADXITMjAzMTM4MjA0MzgyMTQzNDYyOHgAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "14_1777278427.727548", "card_id": "Q_2031655584894820497", "card_label": {"type": "hot", "icon": "https://pic2.zhimg.com/80/v2-266e83dbee46dce23b718e0531cb7d3a_1440w.png", "night_icon": "https://pic3.zhimg.com/80/v2-c89199839c237b87e52f010bb5e7d773_1440w.png"}, "feed_specific": {"answer_count": 25}, "target": {"title_area": {"text": "奇瑞与宁德时代签约，开发换电电池及网络车型，这会带来哪些改变？"}, "excerpt_area": {"text": "4 月 25 日，奇瑞汽车股份有限公司、宁德时代新能源科技股份有限公司、奇瑞绿能生态科技有限公司、时代电服科技有限公司在北京签署战略合作协议。根据协议，奇瑞汽车将开发适配换电电池及换电网络的车型，宁德时代、时代电服负责换电电池的开发迭代与供应保障，奇瑞绿能配套提供全场景绿色能源解决方案。 奇瑞汽车与宁德时代签约，将开发适配换电电池及换电网络车型"}, "image_area": {"url": "https://pic1.zhimg.com/v2-29c5e47305fde3b6ae72f4d7edc295f1.png"}, "metrics_area": {"text": "89 万热度", "font_color": "", "background": "", "weight": ""}, "label_area": {"type": "trend", "trend": 0, "night_color": "#B7302D", "normal_color": "#F1403C"}, "link": {"url": "https://www.zhihu.com/question/2031655584894820497"}}, "attached_info": "CkkI9/vfkdDApJwlEAMaCTExOTI4NDkzOSCVwbXPBjAAOCNADnITMjAzMTY1NTU4NDg5NDgyMDQ5N3gAqgEJYmlsbGJvYXJk0gEA"}, {"type": "hot_list_feed", "style_type": "1", "id": "15_1777278427.728260", "card_id": "Q_2031994357864253235", "card_label": {"type": "new", "icon": "https://pic2.zhimg.com/80/v2-a4b0b52b561281109c5